---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
---

<BaseLayout title="Seguridad — Kuntur Benefits">
  <Navbar currentPage="/seguridad" />

  <main class="pt-16">

    <!-- HERO -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6">

      <!-- Grid -->
      <div
        class="absolute inset-0 z-0"
        style="background-image: linear-gradient(rgba(26,159,125,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(26,159,125,0.04) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 80%);">
      </div>

      <!-- Glow -->
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-green-500/[0.08] blur-3xl pointer-events-none z-0"></div>

      <div class="relative z-10 text-center max-w-4xl mx-auto">

        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-[12px] font-medium mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
          Protección y validación segura
        </div>

        <h1 class="font-display font-800 text-[clamp(36px,6vw,72px)] leading-[1.04] tracking-[-2px] text-white mb-6">
          Seguridad y<br />
          <span class="text-green-400">privacidad</span><br />
          para todos los socios
        </h1>

        <p class="text-[17px] text-white/50 leading-relaxed max-w-[620px] mx-auto mb-10">
          Kuntur Benefits utiliza validaciones seguras, protección de datos y
          tecnologías modernas para garantizar la privacidad de los socios y la
          seguridad de los comercios adheridos.
        </p>

        <div class="flex items-center justify-center gap-4 flex-wrap">
          <a
            href="/beneficios"
            class="flex items-center gap-2 px-6 py-3 rounded-xl bg-green-500 text-white font-display font-600 text-[14px] hover:bg-green-400 transition-all duration-200 shadow-lg shadow-green-500/25">
            Ver beneficios
          </a>

          <a
            href="/comercios"
            class="flex items-center gap-2 px-6 py-3 rounded-xl border border-white/[0.10] text-white/70 font-display font-600 text-[14px] hover:bg-white/[0.05] hover:text-white transition-all duration-200">
            Comercios adheridos
          </a>
        </div>

      </div>
    </section>

    <!-- SECURITY FEATURES -->
    <section class="py-24 px-6 border-t border-white/[0.06] bg-white/[0.02]">
      <div class="max-w-6xl mx-auto">

        <div class="text-center mb-16">
          <p class="text-green-400 text-[11px] font-bold uppercase tracking-widest mb-3">
            Infraestructura segura
          </p>

          <h2 class="font-display font-700 text-[36px] text-white tracking-tight">
            Tecnología pensada para proteger
          </h2>

          <p class="text-white/45 text-[16px] mt-3 max-w-xl mx-auto">
            Toda la plataforma fue diseñada siguiendo estándares modernos de seguridad y privacidad.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">

          {[
            {
              title: 'Validación cifrada',
              text: 'Las consultas entre comercios y servidores utilizan conexiones seguras HTTPS y validación en tiempo real.'
            },
            {
              title: 'Privacidad protegida',
              text: 'Los comercios solo visualizan información mínima necesaria para validar el beneficio.'
            },
            {
              title: 'Monitoreo constante',
              text: 'El sistema registra actividad, accesos y validaciones para prevenir usos indebidos.'
            },
            {
              title: 'Acceso seguro',
              text: 'Los paneles administrativos cuentan con autenticación y control de permisos.'
            },
            {
              title: 'Infraestructura escalable',
              text: 'Arquitectura preparada para soportar miles de validaciones simultáneas.'
            },
            {
              title: 'Respaldo de información',
              text: 'La información crítica cuenta con backups y protección ante pérdidas.'
            }
          ].map(card => (
            <div class="bg-[#0c0f0e] border border-white/[0.06] rounded-2xl p-7 hover:border-white/[0.10] transition-all duration-200 hover:-translate-y-0.5">

              <div class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mb-5">
                <svg class="w-5 h-5 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>

              <h3 class="font-display font-600 text-[18px] text-white mb-3">
                {card.title}
              </h3>

              <p class="text-[14px] text-white/45 leading-relaxed">
                {card.text}
              </p>

            </div>
          ))}

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6">
      <div class="max-w-3xl mx-auto text-center">

        <p class="text-green-400 text-[11px] font-bold uppercase tracking-widest mb-4">
          Plataforma segura
        </p>

        <h2 class="font-display font-700 text-[36px] text-white tracking-tight mb-5">
          Seguridad diseñada para escalar con Kuntur
        </h2>

        <p class="text-white/45 text-[16px] mb-10">
          Devhub desarrolla soluciones modernas, seguras y preparadas para el crecimiento de la comunidad Kuntur.
        </p>

        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-green-500 text-white font-display font-600 text-[14px] hover:bg-green-400 transition-all duration-200 shadow-lg shadow-green-500/25">
          Volver al inicio
        </a>

      </div>
    </section>

  </main>
</BaseLayout>