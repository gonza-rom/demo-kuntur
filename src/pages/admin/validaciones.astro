---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
---

<BaseLayout title="Validaciones — Admin Kuntur Benefits" currentPage="/admin/validaciones">
  <Sidebar role="admin" currentPage="/admin/validaciones" />

  <style is:global>
    :root {
      --bg:#080a09;--bg2:#0c0f0e;--bg3:#111412;--bg4:#161a18;
      --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.10);
      --brand:#1a9f7d;--brand2:#22c9a0;
      --brand-dim:rgba(26,159,125,0.10);
      --danger:#e8192c;--danger-dim:rgba(232,25,44,0.10);
      --amber:#f59e0b;--amber-dim:rgba(245,158,11,0.10);
      --blue:#3b82f6;--blue-dim:rgba(59,130,246,0.10);
      --text:#f0f4f2;--text2:#7a8c85;--text3:#4a5c54;
      --sans:'Syne',sans-serif;--body:'DM Sans',sans-serif;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    a{color:inherit;text-decoration:none}
    button{cursor:pointer;border:none;background:none;font:inherit;color:inherit}

    .admin-main{margin-left:220px;padding:32px 36px;min-height:calc(100vh - 64px);background:var(--bg);font-family:var(--body);color:var(--text)}

    .demo-banner{display:flex;align-items:center;gap:10px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:10px;padding:10px 14px;margin-bottom:24px;font-size:12px;color:var(--amber)}

    .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px}
    .page-title{font-family:var(--sans);font-size:22px;font-weight:700;color:white}
    .page-sub{font-size:13px;color:var(--text2);margin-top:3px}

    .btn-outline{padding:8px 14px;border-radius:8px;border:1px solid var(--border2);color:var(--text2);font-size:13px;font-weight:500;transition:all .15s;display:inline-flex;align-items:center;gap:6px}
    .btn-outline:hover{background:var(--bg3);color:var(--text)}

    /* Stats */
    .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
    .stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:18px 20px;display:flex;align-items:center;justify-content:space-between}
    .stat-label{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
    .stat-value{font-family:var(--sans);font-size:26px;font-weight:700;line-height:1}
    .stat-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}

    /* Chart row */
    .chart-row{display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:20px}
    .chart-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:20px}
    .chart-title{font-family:var(--sans);font-size:14px;font-weight:600;color:white;margin-bottom:4px}
    .chart-sub{font-size:12px;color:var(--text3);margin-bottom:16px}
    .bar-chart{display:flex;align-items:flex-end;gap:6px;height:100px}
    .bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:5px}
    .bar-col{width:100%;border-radius:4px 4px 0 0;transition:opacity .2s}
    .bar-col:hover{opacity:.75}
    .bar-lbl{font-size:10px;color:var(--text3)}
    .donut-list{display:flex;flex-direction:column;gap:10px}
    .donut-row{display:flex;align-items:center;gap:8px}
    .donut-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
    .donut-name{flex:1;font-size:13px;color:var(--text)}
    .donut-bar-bg{flex:2;height:4px;background:var(--bg4);border-radius:2px;overflow:hidden}
    .donut-fill{height:100%;border-radius:2px}
    .donut-pct{font-size:12px;font-weight:600;color:var(--text2);width:32px;text-align:right}

    /* Toolbar */
    .toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px}
    .toolbar-left{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .search-wrap{position:relative}
    .search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:14px;color:var(--text3);pointer-events:none}
    .search-input{background:var(--bg3);border:1px solid var(--border2);border-radius:8px;padding:8px 14px 8px 32px;color:var(--text);font-size:13px;outline:none;width:240px;font-family:var(--body);transition:border-color .15s}
    .search-input:focus{border-color:var(--brand)}
    .search-input::placeholder{color:var(--text3)}
    .filter-btn{display:flex;align-items:center;gap:5px;padding:8px 13px;border-radius:8px;border:1px solid var(--border2);font-size:12px;font-weight:500;color:var(--text2);background:var(--bg3);transition:all .15s}
    .filter-btn:hover{color:var(--text);border-color:var(--brand)}
    .filter-btn.active{background:var(--brand-dim);color:var(--brand2);border-color:rgba(26,159,125,.25)}

    /* Table */
    .table-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;overflow:hidden}
    table{width:100%;border-collapse:collapse;font-size:13px}
    thead th{text-align:left;padding:12px 16px;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);background:var(--bg2);white-space:nowrap}
    tbody td{padding:13px 16px;border-bottom:1px solid rgba(255,255,255,.04);vertical-align:middle}
    tbody tr:last-child td{border-bottom:none}
    tbody tr:hover td{background:rgba(255,255,255,.02)}

    .avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:10px;font-weight:700;flex-shrink:0}
    .socio-cell{display:flex;align-items:center;gap:9px}
    .socio-name{font-weight:500;color:white;font-size:13px}

    .badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;letter-spacing:.3px;text-transform:uppercase;white-space:nowrap}
    .b-green{background:rgba(26,159,125,.12);color:var(--brand2);border:1px solid rgba(26,159,125,.25)}
    .b-red{background:var(--danger-dim);color:#ff8090;border:1px solid rgba(232,25,44,.2)}
    .b-amber{background:var(--amber-dim);color:var(--amber);border:1px solid rgba(245,158,11,.2)}
    .b-blue{background:var(--blue-dim);color:#60a5fa;border:1px solid rgba(59,130,246,.2)}
    .b-gray{background:var(--bg4);color:var(--text3);border:1px solid var(--border)}

    /* Live indicator */
    .live-dot{width:7px;height:7px;border-radius:50%;background:#4ade80;animation:pulse-anim 1.5s infinite;display:inline-block}
    .dot-pulse{width:5px;height:5px;border-radius:50%;background:currentColor;animation:pulse-anim 1.8s infinite;display:inline-block}
    @keyframes pulse-anim{0%,100%{opacity:1}50%{opacity:.3}}

    .pag-info{font-size:12px;color:var(--text3)}
    .pag-btns{display:flex;gap:4px}
    .pag-btn{width:30px;height:30px;border-radius:7px;border:1px solid var(--border2);font-size:12px;color:var(--text2);display:flex;align-items:center;justify-content:center;transition:all .15s;cursor:pointer}
    .pag-btn:hover{border-color:var(--brand);color:var(--brand2)}
    .pag-btn.active{background:var(--brand-dim);border-color:rgba(26,159,125,.3);color:var(--brand2);font-weight:700}
  </style>

  <main class="admin-main">

    <div class="demo-banner">
      🧪 <div><strong>Modo demo</strong> — Datos ficticios. Sin conexión a backend real.</div>
    </div>

    <div class="topbar">
      <div>
        <div style="display:flex;align-items:center;gap:10px">
          <div class="page-title">Validaciones</div>
          <div style="display:flex;align-items:center;gap:6px;padding:4px 10px;background:rgba(74,222,128,.08);border:1px solid rgba(74,222,128,.2);border-radius:20px">
            <div class="live-dot"></div>
            <span style="font-size:11px;font-weight:600;color:#4ade80">En vivo</span>
          </div>
        </div>
        <div class="page-sub">Historial completo de validaciones del ecosistema</div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn-outline">📥 Exportar CSV</button>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card">
        <div><div class="stat-label">Validaciones hoy</div><div class="stat-value" style="color:var(--brand2)" id="kpi-hoy">0</div></div>
        <div class="stat-icon" style="background:var(--brand-dim);color:var(--brand2)">✅</div>
      </div>
      <div class="stat-card">
        <div><div class="stat-label">Este mes</div><div class="stat-value" style="color:#60a5fa" id="kpi-mes">0</div></div>
        <div class="stat-icon" style="background:var(--blue-dim);color:#60a5fa">📅</div>
      </div>
      <div class="stat-card">
        <div><div class="stat-label">Exitosas hoy</div><div class="stat-value" style="color:#4ade80" id="kpi-ok">0</div></div>
        <div class="stat-icon" style="background:rgba(74,222,128,.1);color:#4ade80">🎯</div>
      </div>
      <div class="stat-card">
        <div><div class="stat-label">Rechazadas hoy</div><div class="stat-value" style="color:#ff8090" id="kpi-err">0</div></div>
        <div class="stat-icon" style="background:var(--danger-dim);color:#ff8090">❌</div>
      </div>
    </div>

    <!-- Charts -->
    <div class="chart-row">
      <div class="chart-card">
        <div class="chart-title">Actividad semanal</div>
        <div class="chart-sub">Validaciones por día — últimos 7 días</div>
        <div class="bar-chart" id="bar-chart"></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Por comercio</div>
        <div class="chart-sub">Top 5 comercios este mes</div>
        <div class="donut-list" id="donut-list"></div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
      <div class="toolbar-left">
        <div class="search-wrap">
          <span class="search-icon">🔍</span>
          <input class="search-input" id="search-val" placeholder="Buscar socio, DNI o comercio..." oninput="filterVals()" />
        </div>
        <button class="filter-btn active" onclick="setFilter('todos',this)">Todos</button>
        <button class="filter-btn" onclick="setFilter('exitoso',this)">✅ Exitosos</button>
        <button class="filter-btn" onclick="setFilter('rechazado',this)">❌ Rechazados</button>
      </div>
      <div style="font-size:12px;color:var(--text3)">Mostrando <span id="val-count">16</span> resultados</div>
    </div>

    <!-- Table -->
    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>Socio</th>
            <th>DNI</th>
            <th>Comercio</th>
            <th>Resultado</th>
            <th>Plan</th>
            <th>Beneficio</th>
            <th>Hora</th>
            <th>Fecha</th>
          </tr>
        </thead>
        <tbody id="val-body"></tbody>
      </table>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-top:1px solid var(--border)">
        <div class="pag-info">Página 1 de 243 · 3,891 validaciones</div>
        <div class="pag-btns">
          <button class="pag-btn">‹</button>
          <button class="pag-btn active">1</button>
          <button class="pag-btn">2</button>
          <button class="pag-btn">3</button>
          <button class="pag-btn">…</button>
          <button class="pag-btn">243</button>
          <button class="pag-btn">›</button>
        </div>
      </div>
    </div>

  </main>
</BaseLayout>

<script is:inline>
const VALIDACIONES = [
  { nombre:'Juan Pérez',       av:'JP', ac:'teal',  dni:'32.456.789', comercio:'Cafetería del Centro', resultado:'exitoso',   plan:'Premium',  beneficio:'20% OFF', hora:'10:23', fecha:'09/06/2025' },
  { nombre:'María López',      av:'ML', ac:'teal',  dni:'28.123.456', comercio:'Cafetería del Centro', resultado:'exitoso',   plan:'Standard', beneficio:'20% OFF', hora:'09:48', fecha:'09/06/2025' },
  { nombre:'Carlos Ruiz',      av:'CR', ac:'red',   dni:'41.789.012', comercio:'Cafetería del Centro', resultado:'rechazado', plan:'—',        beneficio:'—',       hora:'09:31', fecha:'09/06/2025' },
  { nombre:'Ana Giménez',      av:'AG', ac:'teal',  dni:'35.654.321', comercio:'Barbería Elite',       resultado:'exitoso',   plan:'Premium',  beneficio:'15% OFF', hora:'09:12', fecha:'09/06/2025' },
  { nombre:'Pablo Torres',     av:'PT', ac:'amber', dni:'30.987.654', comercio:'SportWear Store',      resultado:'exitoso',   plan:'Standard', beneficio:'10% OFF', hora:'08:55', fecha:'09/06/2025' },
  { nombre:'Lucía Fernández',  av:'LF', ac:'teal',  dni:'25.334.455', comercio:'NutriBalance',         resultado:'exitoso',   plan:'Premium',  beneficio:'1ª gratis',hora:'08:30', fecha:'09/06/2025' },
  { nombre:'Valentina Castro', av:'VC', ac:'red',   dni:'44.556.677', comercio:'ProSuplementos',       resultado:'rechazado', plan:'—',        beneficio:'—',       hora:'08:12', fecha:'09/06/2025' },
  { nombre:'Martín Soria',     av:'MS', ac:'teal',  dni:'37.221.100', comercio:'Farmacia Vital',       resultado:'exitoso',   plan:'Standard', beneficio:'8% OFF',  hora:'07:58', fecha:'09/06/2025' },
  { nombre:'Juan Pérez',       av:'JP', ac:'teal',  dni:'32.456.789', comercio:'NutriBalance',         resultado:'exitoso',   plan:'Premium',  beneficio:'1ª gratis',hora:'18:44', fecha:'08/06/2025' },
  { nombre:'Ana Giménez',      av:'AG', ac:'teal',  dni:'35.654.321', comercio:'ProSuplementos',       resultado:'exitoso',   plan:'Premium',  beneficio:'18% OFF', hora:'17:30', fecha:'08/06/2025' },
  { nombre:'Lucía Fernández',  av:'LF', ac:'teal',  dni:'25.334.455', comercio:'Barbería Elite',       resultado:'exitoso',   plan:'Premium',  beneficio:'15% OFF', hora:'16:20', fecha:'08/06/2025' },
  { nombre:'Martín Soria',     av:'MS', ac:'teal',  dni:'37.221.100', comercio:'Cafetería del Centro', resultado:'exitoso',   plan:'Standard', beneficio:'20% OFF', hora:'15:55', fecha:'08/06/2025' },
  { nombre:'Pablo Torres',     av:'PT', ac:'amber', dni:'30.987.654', comercio:'Farmacia Vital',       resultado:'exitoso',   plan:'Standard', beneficio:'8% OFF',  hora:'14:10', fecha:'08/06/2025' },
  { nombre:'Carlos Ruiz',      av:'CR', ac:'red',   dni:'41.789.012', comercio:'ProSuplementos',       resultado:'rechazado', plan:'—',        beneficio:'—',       hora:'13:45', fecha:'08/06/2025' },
  { nombre:'María López',      av:'ML', ac:'teal',  dni:'28.123.456', comercio:'SportWear Store',      resultado:'exitoso',   plan:'Standard', beneficio:'10% OFF', hora:'12:22', fecha:'08/06/2025' },
  { nombre:'Juan Pérez',       av:'JP', ac:'teal',  dni:'32.456.789', comercio:'Barbería Elite',       resultado:'exitoso',   plan:'Premium',  beneficio:'15% OFF', hora:'11:05', fecha:'08/06/2025' },
];

const AV_COLORS = {
  teal:  { bg:'rgba(26,159,125,.12)', color:'#22c9a0' },
  amber: { bg:'rgba(245,158,11,.10)', color:'#f59e0b' },
  red:   { bg:'rgba(232,25,44,.10)',  color:'#ff8090' },
};

const CHART_DATA = [
  { dia:'Lun', val:38 }, { dia:'Mar', val:52 }, { dia:'Mié', val:31 },
  { dia:'Jue', val:67 }, { dia:'Vie', val:74 }, { dia:'Sáb', val:91 }, { dia:'Hoy', val:24 },
];

const TOP_COMERCIOS = [
  { nombre:'Cafetería del Centro', pct:72, color:'var(--brand)' },
  { nombre:'Barbería Elite',       pct:54, color:'#60a5fa' },
  { nombre:'NutriBalance',         pct:41, color:'#4ade80' },
  { nombre:'ProSuplementos',       pct:35, color:'var(--amber)' },
  { nombre:'SportWear Store',      pct:28, color:'#c084fc' },
];

let currentFilter = 'todos';

function countUp(id, target, duration) {
  var el = document.getElementById(id);
  if (!el) return;
  var start = 0; var step = target / (duration / 16);
  var t = setInterval(function() {
    start = Math.min(start + step, target);
    el.textContent = Math.round(start).toLocaleString();
    if (start >= target) clearInterval(t);
  }, 16);
}

function renderBarChart() {
  var max = Math.max.apply(null, CHART_DATA.map(function(d) { return d.val; }));
  document.getElementById('bar-chart').innerHTML = CHART_DATA.map(function(d) {
    var isToday = d.dia === 'Hoy';
    return '<div class="bar-wrap">' +
      '<div class="bar-col" style="height:' + Math.round((d.val/max)*100) + '%;background:' + (isToday ? 'var(--brand)' : 'rgba(26,159,125,.35)') + '"></div>' +
      '<div class="bar-lbl" style="' + (isToday ? 'color:var(--brand2);font-weight:600' : '') + '">' + d.dia + '</div>' +
    '</div>';
  }).join('');
}

function renderDonut() {
  document.getElementById('donut-list').innerHTML = TOP_COMERCIOS.map(function(c) {
    return '<div class="donut-row">' +
      '<div class="donut-dot" style="background:' + c.color + '"></div>' +
      '<div class="donut-name">' + c.nombre + '</div>' +
      '<div class="donut-bar-bg"><div class="donut-fill" style="width:' + c.pct + '%;background:' + c.color + '"></div></div>' +
      '<div class="donut-pct">' + c.pct + '%</div>' +
    '</div>';
  }).join('');
}

function planBadge(p) {
  if (p === 'Premium')  return '<span class="badge b-blue">Premium</span>';
  if (p === 'Standard') return '<span class="badge b-gray">Standard</span>';
  return '<span style="color:var(--text3)">—</span>';
}

function renderTable(data) {
  document.getElementById('val-count').textContent = data.length;
  document.getElementById('val-body').innerHTML = data.map(function(v) {
    var av = AV_COLORS[v.ac] || AV_COLORS.teal;
    var resultBadge = v.resultado === 'exitoso'
      ? '<span class="badge b-green"><span class="dot-pulse"></span>Exitoso</span>'
      : '<span class="badge b-red">❌ Rechazado</span>';
    return '<tr>' +
      '<td><div class="socio-cell">' +
        '<div class="avatar" style="background:' + av.bg + ';color:' + av.color + '">' + v.av + '</div>' +
        '<div class="socio-name">' + v.nombre + '</div>' +
      '</div></td>' +
      '<td style="font-family:monospace;color:var(--text2);font-size:12px">' + v.dni + '</td>' +
      '<td style="color:var(--text2)">' + v.comercio + '</td>' +
      '<td>' + resultBadge + '</td>' +
      '<td>' + planBadge(v.plan) + '</td>' +
      '<td style="color:' + (v.beneficio !== '—' ? 'var(--brand2)' : 'var(--text3)') + ';font-weight:600">' + v.beneficio + '</td>' +
      '<td style="font-family:monospace;color:var(--text3);font-size:12px">' + v.hora + '</td>' +
      '<td style="color:var(--text3);font-size:12px">' + v.fecha + '</td>' +
    '</tr>';
  }).join('');
}

function getFiltered() {
  var q = document.getElementById('search-val').value.toLowerCase();
  return VALIDACIONES.filter(function(v) {
    var matchF = currentFilter === 'todos' || v.resultado === currentFilter;
    var matchQ = !q || v.nombre.toLowerCase().includes(q) || v.dni.includes(q) || v.comercio.toLowerCase().includes(q);
    return matchF && matchQ;
  });
}

function filterVals() { renderTable(getFiltered()); }

function setFilter(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  renderTable(getFiltered());
}

document.addEventListener('DOMContentLoaded', function() {
  countUp('kpi-hoy', 24, 800);
  countUp('kpi-mes', 3891, 1200);
  countUp('kpi-ok',  21, 800);
  countUp('kpi-err', 3, 600);
  renderBarChart();
  renderDonut();
  renderTable(VALIDACIONES);
});
</script>