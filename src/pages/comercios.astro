    emoji: "💊",
    destacado: false,
  },
  {
    nombre: "Librería Caminante",
    categoria: "educacion",
    categoriaLabel: "Educación",
    descuento: "20%",
    descripcion: "Libros, papelería escolar, artículos de arte y material universitario.",
    direccion: "Av. Belgrano 512, San Fernando del Valle",
    emoji: "📚",
    destacado: false,
  },
  {
    nombre: "Heladería El Cóndor",
    categoria: "gastronomia",
    categoriaLabel: "Gastronomía",
    descuento: "12%",
    descripcion: "Helados artesanales con sabores regionales: algarrobo, mistol y cayote.",
    direccion: "Mota Botello 88, San Fernando del Valle",
    emoji: "🍦",
    destacado: false,
  },
  {
