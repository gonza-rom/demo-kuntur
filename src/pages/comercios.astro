    categoria: "salud",
    categoriaLabel: "Salud",
    descuento: "18%",
    descripcion: "Anteojos, lentes de contacto y exámenes visuales con los mejores especialistas.",
    direccion: "Sarmiento 215, San Fernando del Valle",
    emoji: "👓",
    destacado: false,
  },
  {
    nombre: "Muebles & Deco Andina",
    categoria: "hogar",
    categoriaLabel: "Hogar",
    descuento: "10%",
    descripcion: "Muebles y decoración con estética andina, fabricación propia y materiales locales.",
    direccion: "Av. Virgen del Valle 830, San Fernando del Valle",
    emoji: "🪑",
    destacado: true,
  },
  {
    nombre: "Modas Puna",
    categoria: "moda",
    categoriaLabel: "Moda",
    descuento: "15%",
    descripcion: "Ropa femenina y masculina, accesorios y tejidos artesanales de la región.",
    direccion: "República 67, San Fernando del Valle",
    emoji: "👗",
    destacado: false,
  },
  {
    nombre: "TechRepair Cata",
    categoria: "tecnologia",
    categoriaLabel: "Tecnología",
    descuento: "10%",
    descripcion: "Reparación de celulares, tablets, computadoras y venta de accesorios.",
    direccion: "Esquiú 104, San Fernando del Valle",
    emoji: "📱",
    destacado: false,
  },
  {
    nombre: "Café La Pirámide",
