document.addEventListener('DOMContentLoaded', () => {
  countUp('kpi-socios',    1284);
  countUp('kpi-comercios', 47);
  countUp('kpi-val',       3891);
  setTimeout(() => countUp('kpi-tasa', 68, '%'), 200);

  renderBarChart();
  renderDonut();
  renderRanking();
  renderSocios();
  renderComercios();
  renderValidaciones();
});
</script>
