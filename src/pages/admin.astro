// ═══════════════════════════════════════════════
// TABS
// ═══════════════════════════════════════════════
let currentTab = 'ranking';
const panels = ['ranking', 'socios', 'comercios', 'validaciones'];

function switchTab(tab) {
  currentTab = tab;
  panels.forEach(p => {
    const el = document.getElementById(p + '-panel');
    if (el) el.classList.toggle('active', p === tab);
  });
  document.querySelectorAll('#main-tabs .tab').forEach(btn => {
    const t = btn.textContent.toLowerCase();
    const active =
      (tab === 'ranking'      && t.includes('top'))      ||
      (tab === 'socios'       && t.includes('socios'))   ||
      (tab === 'comercios'    && t.includes('comercios'))||
      (tab === 'validaciones' && t.includes('validac'));
    btn.classList.toggle('active', active);
  });
  document.getElementById('search-input').value = '';
  filterTable();
}

function setNavActive(el) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
}

// ═══════════════════════════════════════════════
// SEARCH / FILTER
// ═══════════════════════════════════════════════
function filterTable() {
  const q = document.getElementById('search-input').value.toLowerCase();
  const panel = document.getElementById(currentTab + '-panel');
  if (!panel) return;
  panel.querySelectorAll('tbody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

// ═══════════════════════════════════════════════
// INIT
