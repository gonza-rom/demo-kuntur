---
// admin.astro — Kuntur Benefits · Panel Administrador · Demo local
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Admin — Kuntur Benefits</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"/>
  <style>
    :root {
      --bg:        #080809;
      --bg2:       #0f0f11;
      --bg3:       #141417;
      --bg4:       #1a1a1e;
      --border:    rgba(255,255,255,0.06);
      --border2:   rgba(255,255,255,0.10);
      --brand:     #25a887;
      --brand2:    #2dd4aa;
      --brand-dim: rgba(37,168,135,0.10);
      --brand-glow:rgba(37,168,135,0.25);
      --danger:    #e8192c;
      --danger-dim:rgba(232,25,44,0.10);
      --amber:     #f59e0b;
      --amber-dim: rgba(245,158,11,0.10);
      --blue:      #3b82f6;
      --blue-dim:  rgba(59,130,246,0.10);
      --violet:    #8b5cf6;
      --text:      #f0f0f5;
      --text2:     #8888a0;
      --text3:     #55556a;
      --sans:      'Syne', sans-serif;
      --body:      'DM Sans', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: var(--body); font-size: 14px; line-height: 1.6; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
    button { cursor: pointer; border: none; background: none; font: inherit; color: inherit; }

    /* ── Layout ── */
    .layout { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar {
      width: 230px; flex-shrink: 0;
      background: var(--bg2); border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      padding: 24px 14px;
      position: sticky; top: 0; height: 100vh; overflow-y: auto;
    }
    .sidebar-brand { display: flex; align-items: center; gap: 10px; padding-bottom: 18px; border-bottom: 1px solid var(--border); margin-bottom: 14px; }
    .brand-icon { width: 32px; height: 32px; border-radius: 8px; background: var(--danger); display: flex; align-items: center; justify-content: center; font-family: var(--sans); font-weight: 800; font-size: 14px; color: white; flex-shrink: 0; }
    .brand-name { font-family: var(--sans); font-weight: 700; font-size: 13px; color: var(--text); }
    .brand-sub  { font-size: 10px; color: var(--text3); }

    .admin-badge {
      display: flex; align-items: center; justify-content: center; gap: 6px;
      padding: 5px 8px; border-radius: 6px; margin-bottom: 14px;
      background: var(--danger-dim); border: 1px solid rgba(232,25,44,.2);
      font-family: var(--sans); font-size: 11px; font-weight: 700;
      color: var(--danger); letter-spacing: 1px;
    }
    .admin-badge i { font-size: 14px; }

    .nav-section { font-size: 10px; font-weight: 700; color: var(--text3); letter-spacing: 1px; text-transform: uppercase; padding: 0 10px; margin: 12px 0 6px; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 10px; border-radius: 8px;
      font-size: 13px; font-weight: 500; color: var(--text2);
      margin-bottom: 2px; transition: all .15s;
      border: 1px solid transparent; cursor: pointer;
    }
    .nav-item i { font-size: 16px; flex-shrink: 0; }
    .nav-item:hover { background: var(--bg3); color: var(--text); }
    .nav-item.active { background: var(--brand-dim); color: var(--brand2); border-color: rgba(37,168,135,.15); }
    .nav-count { margin-left: auto; font-size: 10px; background: var(--bg4); border: 1px solid var(--border); padding: 1px 7px; border-radius: 10px; color: var(--text3); }
    .sidebar-spacer { flex: 1; }

    .user-row {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 8px; border-top: 1px solid var(--border);
    }
    .user-av {
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--danger-dim); border: 1px solid rgba(232,25,44,.2);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--sans); font-size: 11px; font-weight: 700;
      color: var(--danger); flex-shrink: 0;
    }
    .sidebar-footer { font-size: 10px; color: var(--text3); text-align: center; padding-top: 10px; border-top: 1px solid var(--border); }
    .sidebar-footer span { color: var(--brand2); font-weight: 600; }

    /* ── Main ── */
    .main { flex: 1; padding: 32px 36px; min-height: 100vh; overflow: hidden; }

    /* ── Demo banner ── */
    .demo-banner {
      display: flex; align-items: center; gap: 10px;
      background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.2);
      border-radius: 10px; padding: 10px 14px; margin-bottom: 22px;
      font-size: 12px; color: var(--amber);
    }
    .demo-banner i { font-size: 16px; flex-shrink: 0; }

    /* ── Top bar ── */
    .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 12px; }
    .page-title { font-family: var(--sans); font-size: 22px; font-weight: 700; color: white; }
    .page-sub   { font-size: 13px; color: var(--text2); margin-top: 3px; }
    .topbar-actions { display: flex; gap: 8px; align-items: center; }

    .btn-outline {
      padding: 8px 14px; border-radius: 8px;
      border: 1px solid var(--border2); color: var(--text2);
      font-size: 13px; font-weight: 500; transition: all .15s;
      display: flex; align-items: center; gap: 6px;
    }
    .btn-outline i { font-size: 15px; }
    .btn-outline:hover { background: var(--bg3); color: var(--text); }
    .btn-primary {
      padding: 8px 16px; border-radius: 8px;
      background: var(--brand); color: white;
      font-family: var(--sans); font-size: 13px; font-weight: 600;
      transition: all .15s; display: flex; align-items: center; gap: 6px;
    }
    .btn-primary i { font-size: 15px; }
    .btn-primary:hover { background: var(--brand2); transform: translateY(-1px); }

    /* ── KPI grid ── */
    .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 22px; }
    .kpi-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 14px; padding: 20px; transition: all .2s;
    }
    .kpi-card:hover { border-color: var(--border2); transform: translateY(-1px); }
    .kpi-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .kpi-label { font-size: 11px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: .5px; }
    .kpi-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
    .kpi-value { font-family: var(--sans); font-size: 30px; font-weight: 700; line-height: 1; margin-bottom: 8px; }
    .kpi-delta { font-size: 12px; display: flex; align-items: center; gap: 4px; }
    .kpi-delta i { font-size: 13px; }
    .delta-up   { color: var(--brand2); }
    .delta-down { color: var(--danger); }
    .delta-warn { color: var(--amber); }

    /* ── Charts row ── */
    .charts-row { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 20px; }
    .card { background: var(--bg2); border: 1px solid var(--border); border-radius: 14px; padding: 20px; }
    .card-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
    .card-title  { font-family: var(--sans); font-size: 14px; font-weight: 600; color: white; }
    .card-sub    { font-size: 12px; color: var(--text3); margin-top: 3px; }

    /* Bar chart */
    .bar-chart { display: flex; align-items: flex-end; gap: 6px; height: 110px; }
    .bar-col-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 5px; }
    .bar-col { width: 100%; border-radius: 4px 4px 0 0; min-height: 4px; transition: opacity .2s; }
    .bar-col:hover { opacity: .8; }
    .bar-lbl { font-size: 10px; color: var(--text3); }

    /* Donut list */
    .donut-list { display: flex; flex-direction: column; gap: 10px; }
    .donut-row  { display: flex; align-items: center; gap: 8px; }
    .donut-dot  { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .donut-name { flex: 1; font-size: 13px; color: var(--text); }
    .donut-pct  { font-size: 12px; font-weight: 600; color: var(--text2); min-width: 34px; text-align: right; }
    .donut-bar-wrap { flex: 2; height: 4px; background: var(--bg4); border-radius: 2px; overflow: hidden; }
    .donut-fill { height: 100%; border-radius: 2px; }

    /* ── Tabs ── */
    .tabs-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; flex-wrap: wrap; gap: 10px; }
    .tabs { display: flex; gap: 2px; background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 4px; }
    .tab {
      padding: 7px 14px; border-radius: 7px;
      font-size: 13px; font-weight: 500; color: var(--text2);
      transition: all .15s; display: flex; align-items: center; gap: 6px;
    }
    .tab i { font-size: 14px; }
    .tab:hover { color: var(--text); }
    .tab.active { background: var(--bg2); color: white; box-shadow: 0 1px 4px rgba(0,0,0,.3); }

    /* ── Search ── */
    .search-wrap { position: relative; display: flex; align-items: center; }
    .search-wrap > i { position: absolute; left: 10px; font-size: 15px; color: var(--text3); pointer-events: none; }
    .search-input {
      background: var(--bg3); border: 1px solid var(--border2);
      border-radius: 8px; padding: 8px 14px 8px 32px; color: var(--text);
      font-size: 13px; outline: none; width: 220px;
      transition: border-color .15s;
    }
    .search-input:focus { border-color: var(--brand); }
    .search-input::placeholder { color: var(--text3); }

    /* ── Tables ── */
    .table-wrap { overflow-x: auto; border-radius: 14px; border: 1px solid var(--border); }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th { text-align: left; padding: 12px 16px; font-size: 10px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: .5px; border-bottom: 1px solid var(--border); background: var(--bg2); }
    tbody td { padding: 13px 16px; border-bottom: 1px solid rgba(255,255,255,.04); }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: rgba(255,255,255,.02); }

    /* Badges */
    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 10px; font-weight: 700; padding: 3px 9px;
      border-radius: 20px; letter-spacing: .3px; text-transform: uppercase;
    }
    .badge i { font-size: 11px; }
    .b-green  { background: rgba(37,168,135,.12); color: var(--brand2); border: 1px solid rgba(37,168,135,.25); }
    .b-red    { background: var(--danger-dim); color: #ff8090; border: 1px solid rgba(232,25,44,.2); }
    .b-amber  { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(245,158,11,.2); }
    .b-blue   { background: var(--blue-dim); color: #60a5fa; border: 1px solid rgba(59,130,246,.2); }
    .b-gray   { background: var(--bg4); color: var(--text3); border: 1px solid var(--border); }
    .b-violet { background: rgba(139,92,246,.1); color: #a78bfa; border: 1px solid rgba(139,92,246,.2); }

    .dot-pulse { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse 1.8s infinite; display: inline-block; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

    .avatar { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--sans); font-size: 10px; font-weight: 700; flex-shrink: 0; }

    /* ── Tab panels ── */
    #socios-panel, #comercios-panel, #validaciones-panel { display: none; }
    #socios-panel.active, #comercios-panel.active, #validaciones-panel.active { display: block; }

    /* ── Progress bar ── */
    .progress { height: 5px; background: var(--bg4); border-radius: 3px; overflow: hidden; margin-top: 4px; }
    .progress-bar { height: 100%; border-radius: 3px; }

    /* ── Action button ── */
    .action-btn {
      font-size: 12px; color: var(--text2); padding: 4px 10px;
      border: 1px solid var(--border); border-radius: 6px;
      transition: all .15s; display: inline-flex; align-items: center; gap: 5px;
    }
    .action-btn i { font-size: 13px; }
    .action-btn:hover { border-color: var(--brand); color: var(--brand2); }

    @keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
    .fade-in { animation: fadeIn .3s ease; }
  </style>
</head>
<body>
<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">K</div>
      <div>
        <div class="brand-name">Kuntur Training</div>
        <div class="brand-sub">Panel Administrativo</div>
      </div>
    </div>

    <div class="admin-badge">
      <i class="ti ti-bolt" aria-hidden="true"></i>ADMIN
    </div>

    <div class="nav-section">Analytics</div>
    <a href="/admin" class="nav-item active">
      <i class="ti ti-chart-bar" aria-hidden="true"></i>Dashboard
    </a>

    <div class="nav-section">Gestión</div>
    <a href="#" class="nav-item" onclick="switchTab('socios');setNavActive(this);return false;">
      <i class="ti ti-users" aria-hidden="true"></i>Socios<span class="nav-count">8</span>
    </a>
    <a href="#" class="nav-item" onclick="switchTab('comercios');setNavActive(this);return false;">
      <i class="ti ti-building-store" aria-hidden="true"></i>Comercios<span class="nav-count">6</span>
    </a>
    <a href="#" class="nav-item" onclick="switchTab('validaciones');setNavActive(this);return false;">
      <i class="ti ti-circle-check" aria-hidden="true"></i>Validaciones
    </a>
    <a href="#" class="nav-item">
      <i class="ti ti-gift" aria-hidden="true"></i>Beneficios
    </a>

    <div class="nav-section">Sistema</div>
    <a href="#" class="nav-item">
      <i class="ti ti-settings" aria-hidden="true"></i>Configuración
    </a>
    <a href="/validar" class="nav-item">
      <i class="ti ti-scan" aria-hidden="true"></i>Validar Socio
    </a>
    <a href="#" class="nav-item">
      <i class="ti ti-logout" aria-hidden="true"></i>Cerrar sesión
    </a>

    <div class="sidebar-spacer"></div>

    <div class="user-row">
      <div class="user-av">KT</div>
      <div>
        <div style="font-size:12px;font-weight:600;color:white;">Admin Kuntur</div>
        <div style="font-size:10px;color:var(--text3);">Super Administrador</div>
      </div>
    </div>
    <div class="sidebar-footer">Devhub · <span>Kuntur Benefits</span> v1.0</div>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- Demo banner -->
    <div class="demo-banner">
      <i class="ti ti-flask" aria-hidden="true"></i>
      <div><strong>Modo demo</strong> — Todos los datos son ficticios. Sin conexión a backend.</div>
    </div>

    <!-- Top bar -->
    <div class="topbar">
      <div>
        <div class="page-title">Analytics Global</div>
        <div class="page-sub">Vista completa del ecosistema Kuntur Benefits</div>
      </div>
      <div class="topbar-actions">
        <select style="background:var(--bg3);border:1px solid var(--border2);color:var(--text2);padding:8px 12px;border-radius:8px;font-size:13px;outline:none;">
          <option>Últimos 30 días</option>
          <option>Última semana</option>
          <option>Este año</option>
        </select>
        <button class="btn-outline">
          <i class="ti ti-download" aria-hidden="true"></i>Exportar
        </button>
        <button class="btn-primary">
          <i class="ti ti-plus" aria-hidden="true"></i>Nuevo comercio
        </button>
      </div>
    </div>

    <!-- KPIs -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-label">Socios activos</div>
          <div class="kpi-icon" style="background:var(--brand-dim);color:var(--brand2);">
            <i class="ti ti-users" aria-hidden="true"></i>
          </div>
        </div>
        <div class="kpi-value" style="color:var(--brand2);" id="kpi-socios">0</div>
        <div class="kpi-delta delta-up">
          <i class="ti ti-trending-up" aria-hidden="true"></i>+43 este mes
        </div>
        <div class="progress" style="margin-top:10px;"><div class="progress-bar" style="width:82%;background:var(--brand);"></div></div>
      </div>
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-label">Comercios adheridos</div>
          <div class="kpi-icon" style="background:var(--blue-dim);color:#60a5fa;">
            <i class="ti ti-building-store" aria-hidden="true"></i>
          </div>
        </div>
        <div class="kpi-value" style="color:#60a5fa;" id="kpi-comercios">0</div>
        <div class="kpi-delta delta-up">
          <i class="ti ti-trending-up" aria-hidden="true"></i>+2 este mes
        </div>
        <div class="progress" style="margin-top:10px;"><div class="progress-bar" style="width:60%;background:var(--blue);"></div></div>
      </div>
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-label">Validaciones del mes</div>
          <div class="kpi-icon" style="background:rgba(139,92,246,.1);color:#c084fc;">
            <i class="ti ti-circle-check" aria-hidden="true"></i>
          </div>
        </div>
        <div class="kpi-value" style="color:#c084fc;" id="kpi-val">0</div>
        <div class="kpi-delta delta-up">
          <i class="ti ti-trending-up" aria-hidden="true"></i>+18% vs mes anterior
        </div>
        <div class="progress" style="margin-top:10px;"><div class="progress-bar" style="width:73%;background:var(--violet);"></div></div>
      </div>
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-label">Tasa de conversión</div>
          <div class="kpi-icon" style="background:var(--amber-dim);color:var(--amber);">
            <i class="ti ti-percentage" aria-hidden="true"></i>
          </div>
        </div>
        <div class="kpi-value" style="color:var(--amber);" id="kpi-tasa">0%</div>
        <div class="kpi-delta delta-warn">
          <i class="ti ti-minus" aria-hidden="true"></i>Estable vs mes anterior
        </div>
        <div class="progress" style="margin-top:10px;"><div class="progress-bar" style="width:68%;background:var(--amber);"></div></div>
      </div>
    </div>

    <!-- Charts -->
    <div class="charts-row">
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Validaciones por día</div>
            <div class="card-sub">Últimos 7 días · todas las sucursales</div>
          </div>
          <span class="badge b-green">
            <i class="ti ti-trending-up" aria-hidden="true"></i>+18%
          </span>
        </div>
        <div class="bar-chart" id="bar-chart"></div>
      </div>
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Por categoría</div>
            <div class="card-sub">Beneficios más usados</div>
          </div>
        </div>
        <div class="donut-list" id="donut-list"></div>
      </div>
    </div>

    <!-- Tabs + Tables -->
    <div class="card" style="padding:20px;">
      <div class="tabs-row">
        <div class="tabs" id="main-tabs">
          <button class="tab active" onclick="switchTab('ranking')">
            <i class="ti ti-trophy" aria-hidden="true"></i>Top Comercios
          </button>
          <button class="tab" onclick="switchTab('socios')">
            <i class="ti ti-users" aria-hidden="true"></i>Socios
          </button>
          <button class="tab" onclick="switchTab('comercios')">
            <i class="ti ti-building-store" aria-hidden="true"></i>Comercios
          </button>
          <button class="tab" onclick="switchTab('validaciones')">
            <i class="ti ti-circle-check" aria-hidden="true"></i>Últimas Validaciones
          </button>
        </div>
        <div class="search-wrap">
          <i class="ti ti-search" aria-hidden="true"></i>
          <input class="search-input" id="search-input" placeholder="Buscar..." oninput="filterTable()" />
        </div>
      </div>

      <!-- Tab: Ranking comercios -->
      <div id="ranking-panel" class="active fade-in">
        <div class="table-wrap">
          <table id="ranking-table">
            <thead>
              <tr>
                <th>#</th><th>Comercio</th><th>Rubro</th>
                <th>Validaciones</th><th>Beneficios</th><th>Tasa</th><th>Estado</th>
              </tr>
            </thead>
            <tbody id="ranking-body"></tbody>
          </table>
        </div>
      </div>

      <!-- Tab: Socios -->
      <div id="socios-panel" class="fade-in">
        <div class="table-wrap">
          <table id="socios-table">
            <thead>
              <tr>
                <th>Socio</th><th>DNI</th><th>Plan</th>
                <th>Estado</th><th>Vencimiento</th><th>Alta</th>
              </tr>
            </thead>
            <tbody id="socios-body"></tbody>
          </table>
        </div>
      </div>

      <!-- Tab: Comercios -->
      <div id="comercios-panel" class="fade-in">
        <div class="table-wrap">
          <table id="comercios-table">
            <thead>
              <tr>
                <th>Comercio</th><th>Rubro</th><th>Beneficio</th>
                <th>Validaciones</th><th>Tasa</th><th>Estado</th><th>Acciones</th>
              </tr>
            </thead>
            <tbody id="comercios-body"></tbody>
          </table>
        </div>
      </div>

      <!-- Tab: Validaciones -->
