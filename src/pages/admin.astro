const CATEGORIAS = [
  { nombre:'Gastronomía',  pct:72, color:'var(--brand)' },
  { nombre:'Barbería',     pct:54, color:'var(--blue)' },
  { nombre:'Nutrición',    pct:41, color:'#34d399' },
  { nombre:'Indumentaria', pct:35, color:'var(--amber)' },
