  { nombre:'Carlos Ruiz',      avatar:'CR', ac:'red',   dni:'41.789.012', comercio:'Cafetería del Centro', resultado:'rechazado', plan:'—',        hora:'09:31', beneficio:'—' },
  { nombre:'Ana Giménez',      avatar:'AG', ac:'teal',  dni:'35.654.321', comercio:'Barbería Elite',       resultado:'exitoso',   plan:'Premium',  hora:'09:12', beneficio:'15% OFF' },
  { nombre:'Pablo Torres',     avatar:'PT', ac:'amber', dni:'30.987.654', comercio:'SportWear Store',      resultado:'exitoso',   plan:'Standard', hora:'08:55', beneficio:'10% OFF' },
  { nombre:'Lucía Fernández',  avatar:'LF', ac:'teal',  dni:'25.334.455', comercio:'NutriBalance',         resultado:'exitoso',   plan:'Premium',  hora:'08:30', beneficio:'1ª gratis' },
