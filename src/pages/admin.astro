];

// Mapa de colores para avatares según ac (color category)
const AV_COLORS = {
  teal:  { bg: 'rgba(37,168,135,.12)',  text: 'var(--brand2)' },
  amber: { bg: 'rgba(245,158,11,.10)',  text: 'var(--amber)' },
  red:   { bg: 'rgba(232,25,44,.10)',   text: '#ff8090' },
};
function avStyle(ac) {
  const s = AV_COLORS[ac] || AV_COLORS.teal;
  return `background:${s.bg};color:${s.text};`;
}

// ═══════════════════════════════════════════════
// KPI COUNT-UP ANIMATION
// ═══════════════════════════════════════════════
function countUp(id, target, suffix = '', duration = 1000) {
  const el = document.getElementById(id);
  if (!el) return;
  let start = 0;
  const step = target / (duration / 16);
  const t = setInterval(() => {
    start = Math.min(start + step, target);
    el.textContent = Math.round(start).toLocaleString() + suffix;
    if (start >= target) clearInterval(t);
  }, 16);
}

// ═══════════════════════════════════════════════
// BAR CHART
// ═══════════════════════════════════════════════
function renderBarChart() {
  const max = Math.max(...CHART_DATA.map(d => d.val));
  document.getElementById('bar-chart').innerHTML = CHART_DATA.map(d => `
    <div class="bar-col-wrap">
      <div class="bar-col" style="height:${(d.val / max) * 100}%;background:${d.dia === 'Sáb' ? 'var(--brand)' : 'rgba(37,168,135,.45)'};"></div>
      <div class="bar-lbl" style="${d.dia === 'Sáb' ? 'color:var(--brand2);font-weight:700;' : ''}">${d.dia}</div>
    </div>`).join('');
}

// ═══════════════════════════════════════════════
// DONUT LIST
// ═══════════════════════════════════════════════
function renderDonut() {
  document.getElementById('donut-list').innerHTML = CATEGORIAS.map(c => `
    <div class="donut-row">
      <div class="donut-dot" style="background:${c.color};"></div>
      <div class="donut-name">${c.nombre}</div>
      <div class="donut-bar-wrap"><div class="donut-fill" style="width:${c.pct}%;background:${c.color};"></div></div>
      <div class="donut-pct">${c.pct}%</div>
    </div>`).join('');
}

// ═══════════════════════════════════════════════
// BADGE HELPERS
// ═══════════════════════════════════════════════
function estadoBadge(e) {
  if (e === 'activo')     return '<span class="badge b-green"><span class="dot-pulse" style="color:var(--brand2);"></span>Activo</span>';
  if (e === 'inactivo')   return '<span class="badge b-red"><i class="ti ti-circle-x" aria-hidden="true"></i>Inactivo</span>';
  if (e === 'por-vencer') return '<span class="badge b-amber"><i class="ti ti-clock" aria-hidden="true"></i>Por vencer</span>';
  if (e === 'pendiente')  return '<span class="badge b-amber"><i class="ti ti-clock" aria-hidden="true"></i>Pendiente</span>';
  return `<span class="badge b-gray">${e}</span>`;
}

function planBadge(p) {
  if (p === 'Premium')  return '<span class="badge b-blue"><i class="ti ti-star" aria-hidden="true"></i>Premium</span>';
  if (p === 'Standard') return '<span class="badge b-gray">Standard</span>';
  return `<span style="color:var(--text3);">—</span>`;
}

// ═══════════════════════════════════════════════
// RENDER TABLES
// ═══════════════════════════════════════════════
function renderRanking() {
  const medals = ['🥇', '🥈', '🥉'];
  document.getElementById('ranking-body').innerHTML = COMERCIOS.map((c, i) => {
    const tasa = Math.round((c.benefAplicados / c.validaciones) * 100);
    return `<tr>
      <td style="font-size:17px;">${medals[i] ?? `<span style="color:var(--text3);font-weight:600;">${i + 1}</span>`}</td>
      <td>
        <div style="display:flex;align-items:center;gap:9px;">
          <i class="ti ${c.icon}" style="font-size:18px;color:var(--text2);" aria-hidden="true"></i>
          <span style="font-weight:600;color:white;">${c.nombre}</span>
        </div>
      </td>
      <td><span class="badge b-gray">${c.rubro}</span></td>
      <td style="font-family:'Syne',sans-serif;font-weight:700;color:white;">${c.validaciones.toLocaleString()}</td>
      <td style="color:var(--text2);">${c.benefAplicados.toLocaleString()}</td>
      <td style="font-weight:600;color:${tasa > 70 ? 'var(--brand2)' : 'var(--amber)'};">${tasa}%</td>
      <td>${estadoBadge(c.estado)}</td>
    </tr>`;
  }).join('');
}

