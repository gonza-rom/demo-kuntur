---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<BaseLayout title="Dashboard — Cafetería Mitre · Kuntur Benefits">
  <Sidebar role="comercio" currentPage="/dashboard" comercioName="Cafetería Mitre" />

  <main class="ml-[220px] pt-16 min-h-screen">
    <div class="p-8">

      <!-- Header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="font-display font-700 text-[22px] text-white">Dashboard</h1>
          <p class="text-[13px] text-white/40 mt-0.5">Jueves 14 de mayo, 2026 · Catamarca</p>
        </div>
        <div class="flex gap-3">
          <button class="flex items-center gap-2 px-4 py-2.5 rounded-xl border border-white/[0.08] text-white/60 text-[13px] font-medium hover:bg-white/[0.04] hover:text-white transition-all">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Exportar
          </button>
          <a href="/validar" class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-brand-500 text-white text-[13px] font-medium hover:bg-brand-400 transition-all shadow-lg shadow-brand-500/20">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Validar Socio
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 mb-7">
        {[
          { label: 'Validaciones hoy', value: '24', sub: '↑ +3 vs. ayer', color: 'text-brand-400' },
          { label: 'Beneficios aplicados este mes', value: '218', sub: '↑ +12% vs. mes anterior', color: 'text-blue-400' },
          { label: 'Clientes activos únicos', value: '89', sub: '↑ +7 este mes', color: 'text-amber-400' },
        ].map(s => (
          <div class="bg-[#0c0f0e] border border-white/[0.06] rounded-2xl p-5 hover:border-white/[0.10] transition-all hover:-translate-y-0.5">
            <p class="text-[11px] text-white/35 uppercase tracking-wider mb-3">{s.label}</p>
            <p class={`font-display font-700 text-[32px] leading-none ${s.color}`}>{s.value}</p>
            <p class="text-[12px] text-brand-400/70 mt-2">{s.sub}</p>
          </div>
        ))}
      </div>

      <!-- Charts row -->
      <div class="grid grid-cols-[1fr_280px] gap-5 mb-7">
        <!-- Bar chart -->
        <div class="bg-[#0c0f0e] border border-white/[0.06] rounded-2xl p-6">
          <div class="flex items-center justify-between mb-5">
            <div>
              <p class="font-display font-600 text-[14px] text-white">Actividad semanal</p>
              <p class="text-[12px] text-white/35 mt-0.5">Validaciones por día — últimos 7 días</p>
            </div>
            <span class="text-[11px] font-bold px-2.5 py-1 rounded-full bg-brand-500/10 text-brand-400 border border-brand-500/20">+18% ↑</span>
          </div>
          <div class="flex items-end gap-3 h-28">
            {[
              { day: 'L', h: 45 }, { day: 'M', h: 60 }, { day: 'X', h: 35 },
              { day: 'J', h: 80 }, { day: 'V', h: 70 }, { day: 'S', h: 90 }, { day: 'D', h: 100 }
            ].map(b => (
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full rounded-t-lg bg-brand-500/25 hover:bg-brand-500/50 transition-colors duration-200 cursor-pointer" style={`height: ${b.h}%`}></div>
                <span class={`text-[11px] ${b.day === 'D' ? 'text-white font-600' : 'text-white/30'}`}>{b.day}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Active benefit -->
        <div class="bg-[#0c0f0e] border border-white/[0.06] rounded-2xl p-6">
          <p class="font-display font-600 text-[14px] text-white mb-1">Beneficio activo</p>
          <p class="text-[12px] text-white/35 mb-5">Configurado por Kuntur Training</p>
          <div class="bg-brand-500/10 border border-brand-500/20 rounded-xl p-5 text-center mb-4">
            <p class="font-display font-800 text-[42px] leading-none text-brand-400">20%</p>
            <p class="font-display font-600 text-[18px] text-brand-300 -mt-1">OFF</p>
            <p class="text-[12px] text-white/40 mt-2">En consumo de cafetería</p>
          </div>
          <p class="text-[12px] text-white/30 text-center leading-relaxed">Aplica para socios con plan Premium y Standard</p>
        </div>
      </div>

      <!-- Recent validations table -->
      <div class="bg-[#0c0f0e] border border-white/[0.06] rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-white/[0.06] flex items-center justify-between">
          <div>
            <p class="font-display font-600 text-[14px] text-white">Últimas validaciones</p>
            <p class="text-[12px] text-white/35 mt-0.5">Registro de socios validados hoy</p>
          </div>
          <button class="text-[12px] text-white/40 hover:text-white/70 transition-colors">Ver todo →</button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-[13px]">
            <thead>
              <tr class="border-b border-white/[0.04]">
                {['Socio', 'DNI', 'Estado', 'Plan', 'Beneficio', 'Hora'].map(h => (
                  <th class="text-left px-6 py-3 text-[11px] font-bold text-white/25 uppercase tracking-wider">{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {[
                { nombre: 'Juan Pérez', ini: 'JP', dni: '32.456.789', estado: 'Activo', plan: 'Premium', hora: '10:23', color: 'brand' },
                { nombre: 'María López', ini: 'ML', dni: '28.123.456', estado: 'Activa', plan: 'Standard', hora: '09:48', color: 'brand' },
                { nombre: 'Carlos Ruiz', ini: 'CR', dni: '41.789.012', estado: 'Inactivo', plan: '—', hora: '09:31', color: 'red' },
                { nombre: 'Ana Giménez', ini: 'AG', dni: '35.654.321', estado: 'Activa', plan: 'Premium', hora: '09:12', color: 'brand' },
                { nombre: 'Pablo Torres', ini: 'PT', dni: '30.987.654', estado: 'Por vencer', plan: 'Standard', hora: '08:55', color: 'amber' },
              ].map(row => (
                <tr class="border-b border-white/[0.03] hover:bg-white/[0.015] transition-colors">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class={`w-7 h-7 rounded-full flex items-center justify-center text-[11px] font-bold shrink-0
                        ${row.color === 'brand' ? 'bg-brand-500/15 text-brand-400' : ''}
                        ${row.color === 'red' ? 'bg-rose-500/15 text-rose-400' : ''}
                        ${row.color === 'amber' ? 'bg-amber-500/15 text-amber-400' : ''}
                      `}>{row.ini}</div>
                      <span class="text-white/80 font-medium">{row.nombre}</span>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-white/40 font-mono text-[12px]">{row.dni}</td>
                  <td class="px-6 py-4">
                    <span class={`inline-flex items-center gap-1.5 text-[11px] font-bold px-2.5 py-1 rounded-full
                      ${row.color === 'brand' ? 'bg-brand-500/10 text-brand-400 border border-brand-500/20' : ''}
                      ${row.color === 'red' ? 'bg-rose-500/10 text-rose-400 border border-rose-500/20' : ''}
                      ${row.color === 'amber' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : ''}
                    `}>
                      {row.color === 'brand' && <span class="w-1 h-1 rounded-full bg-brand-400 animate-pulse"></span>}
                      {row.estado}
                    </span>
                  </td>
                  <td class="px-6 py-4">
                    {row.plan !== '—' && (
                      <span class={`text-[11px] font-bold px-2 py-0.5 rounded-md ${row.plan === 'Premium' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20' : 'bg-white/[0.05] text-white/40 border border-white/[0.06]'}`}>
                        {row.plan}
                      </span>
                    )}
                    {row.plan === '—' && <span class="text-white/20">—</span>}
                  </td>
                  <td class="px-6 py-4">
                    {row.color !== 'red' ? (
                      <span class="text-[12px] text-white/50 bg-white/[0.04] border border-white/[0.06] px-2 py-0.5 rounded-md">☕ 20% OFF</span>
                    ) : (
                      <span class="text-[12px] text-white/20">Sin beneficio</span>
                    )}
                  </td>
                  <td class="px-6 py-4 text-white/30 text-[12px]">{row.hora}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>