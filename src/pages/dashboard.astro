---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<BaseLayout title="Dashboard — Cafetería Mitre · Kuntur Benefits" currentPage="/dashboard">
  <Sidebar role="comercio" currentPage="/dashboard" comercioName="Cafetería Mitre" />

  <style is:global>
    :root {
      --bg:       #080a09;
      --bg2:      #0c0f0e;
      --bg3:      #111412;
      --bg4:      #161a18;
      --border:   rgba(255,255,255,0.06);
      --border2:  rgba(255,255,255,0.10);
      --brand:    #24967D;
      --brand2:   #2db896;
      --brand-dim:  rgba(36,150,125,0.10);
      --brand-glow: rgba(36,150,125,0.25);
      --danger:     #e8192c;
      --danger-dim: rgba(232,25,44,0.10);
      --amber:      #f59e0b;
      --amber-dim:  rgba(245,158,11,0.10);
      --blue:       #3b82f6;
      --blue-dim:   rgba(59,130,246,0.10);
      --text:  #f0f4f2;
      --text2: #7a8c85;
      --text3: #4a5c54;
      --sans: 'Space Grotesk', 'Inter', sans-serif;
      --body: 'Inter', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    a    { color: inherit; text-decoration: none; }
    button { cursor: pointer; border: none; background: none; font: inherit; color: inherit; }

    /* ── Animations ── */
    @keyframes fadeIn   { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
    @keyframes pulse    { 0%,100% { opacity:1; } 50% { opacity:.35; } }
    @keyframes spin     { to { transform:rotate(360deg); } }

    /* ── Badges ── */
    .badge { display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;letter-spacing:.3px;text-transform:uppercase;white-space:nowrap; }
    .b-green  { background:rgba(36,150,125,.12);  color:var(--brand2); border:1px solid rgba(36,150,125,.25); }
    .b-red    { background:var(--danger-dim);      color:#ff8090;       border:1px solid rgba(232,25,44,.2); }
    .b-amber  { background:var(--amber-dim);       color:var(--amber);  border:1px solid rgba(245,158,11,.2); }
    .b-blue   { background:var(--blue-dim);        color:#60a5fa;       border:1px solid rgba(59,130,246,.2); }
    .b-gray   { background:var(--bg4);             color:var(--text3);  border:1px solid var(--border); }
    .dot-pulse { width:5px;height:5px;border-radius:50%;background:currentColor;animation:pulse 1.8s infinite;display:inline-block; }
  </style>

  <style>
    /* ── Layout ── */
    .dash-main {
      margin-left: 220px;
      padding: 36px;
      min-height: calc(100vh - 64px);
      background: var(--bg);
      font-family: var(--body);
      color: var(--text);
    }

    /* ── Demo banner ── */
    .demo-banner {
      display:flex;align-items:center;gap:10px;
      background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.18);
      border-radius:10px;padding:10px 14px;margin-bottom:24px;
      font-size:12px;color:var(--amber);
    }

    /* ── Page header ── */
    .topbar { display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px; }
    .page-title { font-family:var(--sans);font-size:22px;font-weight:700;color:white; }
    .page-sub   { font-size:13px;color:var(--text2);margin-top:3px; }

    /* ── Buttons ── */
    .btn-primary {
      display:flex;align-items:center;gap:7px;padding:9px 16px;
      border-radius:9px;background:var(--brand);color:white;
      font-family:var(--sans);font-size:13px;font-weight:600;
      transition:all .15s;box-shadow:0 4px 14px var(--brand-glow);
    }
    .btn-primary:hover { background:var(--brand2);transform:translateY(-1px); }
    .btn-secondary {
      display:flex;align-items:center;gap:7px;padding:9px 16px;
      border-radius:9px;border:1px solid var(--border2);color:var(--text2);
      font-size:13px;font-weight:500;transition:all .15s;
    }
    .btn-secondary:hover { background:var(--bg3);color:white; }

    /* ── Stat cards ── */
    .stats-row { display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px; }
    .stat-card {
      background:var(--bg2);border:1px solid var(--border);border-radius:16px;
      padding:20px;transition:all .2s;
    }
    .stat-card:hover { border-color:var(--border2);transform:translateY(-1px); }
    .stat-top  { display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px; }
    .stat-label { font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.5px; }
    .stat-icon  {
      width:34px;height:34px;border-radius:9px;
      display:flex;align-items:center;justify-content:center;flex-shrink:0;
    }
    .stat-value { font-family:var(--sans);font-size:32px;font-weight:700;line-height:1; }
    .stat-sub   { font-size:12px;margin-top:6px;opacity:.7; }

    /* ── Chart row ── */
    .charts-row { display:grid;grid-template-columns:1fr 276px;gap:16px;margin-bottom:22px; }
    .card { background:var(--bg2);border:1px solid var(--border);border-radius:16px;transition:border-color .2s; }
    .card-pad { padding:22px 24px; }
    .card-title { font-family:var(--sans);font-size:14px;font-weight:600;color:white; }
    .card-sub   { font-size:12px;color:var(--text2);margin-top:2px; }

    /* ── SVG chart ── */
    .chart-wrap { display:flex;gap:0;margin-top:18px; }
    .y-labels {
      display:flex;flex-direction:column;justify-content:space-between;
      padding-bottom:22px;margin-right:10px;flex-shrink:0;
      font-size:10px;color:var(--text3);
    }
    .chart-inner { flex:1;position:relative; }
    .chart-svg   { width:100%;height:120px;overflow:visible; }
    .bar-rect    { transition:opacity .2s; }
    .bar-rect:hover { opacity:.75; }
    .x-labels {
      display:flex;padding-top:6px;
      font-size:11px;color:var(--text3);
    }
    .x-labels span { flex:1;text-align:center; }
    .x-labels .today { color:var(--brand2);font-weight:600; }

    /* ── Benefit active box ── */
    .benefit-box {
      background:rgba(36,150,125,.08);border:1px solid rgba(36,150,125,.18);
      border-radius:12px;padding:20px;text-align:center;flex:1;
      display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
    }
    .benefit-eyebrow { font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--text3);margin-bottom:6px; }
    .benefit-pct  { font-family:var(--sans);font-size:46px;font-weight:800;color:var(--brand2);line-height:1; }
    .benefit-off  { font-family:var(--sans);font-size:18px;font-weight:700;color:var(--brand2);opacity:.75;margin-top:-4px; }
    .benefit-desc { font-size:12px;color:var(--text2);margin-top:6px; }
    .benefit-note { font-size:11px;color:var(--text3);text-align:center;margin-top:12px;line-height:1.5; }

    /* ── Table card ── */
    .table-card { background:var(--bg2);border:1px solid var(--border);border-radius:16px;overflow:hidden; }
    .table-header {
      padding:16px 22px;border-bottom:1px solid var(--border);
      display:flex;align-items:center;justify-content:space-between;
    }
    .tbl-action { font-size:12px;color:var(--text2);transition:color .15s; }
    .tbl-action:hover { color:white; }
    table    { width:100%;border-collapse:collapse;font-size:13px; }
    thead th {
      text-align:left;padding:11px 20px;
      font-size:10px;font-weight:700;color:var(--text3);
      text-transform:uppercase;letter-spacing:.5px;
      border-bottom:1px solid var(--border);background:var(--bg2);
    }
    tbody td { padding:13px 20px;border-bottom:1px solid rgba(255,255,255,.04);vertical-align:middle; }
    tbody tr:last-child td { border-bottom:none; }
    tbody tr:hover td     { background:rgba(255,255,255,.015); }

    /* ── Avatar ── */
    .avatar {
      width:28px;height:28px;border-radius:50%;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
      font-size:10px;font-weight:700;
    }
    .av-brand  { background:rgba(36,150,125,.14); color:var(--brand2); }
    .av-danger { background:var(--danger-dim);    color:#ff8090; }
    .av-amber  { background:var(--amber-dim);     color:var(--amber); }

    /* ── Benefit tag ── */
    .benefit-tag {
      font-size:12px;color:var(--text2);
      background:var(--bg4);border:1px solid var(--border);
      padding:3px 9px;border-radius:6px;font-weight:500;white-space:nowrap;
    }
  </style>

  <main class="dash-main">

    <!-- Demo banner -->
    <div class="demo-banner">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <div><strong>Modo demo</strong> — Datos ficticios. Sin conexión a backend real.</div>
    </div>

    <!-- Header -->
    <div class="topbar">
      <div>
        <div class="page-title">Dashboard</div>
        <div class="page-sub">Jueves 14 de mayo, 2026 · Catamarca</div>
      </div>
      <div style="display:flex;gap:10px;">
        <button class="btn-secondary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Exportar
        </button>
        <a href="/validar" class="btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Validar Socio
        </a>
      </div>
    </div>

    <!-- Stat cards -->
    <div class="stats-row">

      <div class="stat-card">
        <div class="stat-top">
          <div class="stat-label">Validaciones hoy</div>
          <div class="stat-icon" style="background:rgba(36,150,125,.1);border:1px solid rgba(36,150,125,.15);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#24967D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </div>
        </div>
        <div class="stat-value" style="color:var(--brand2);">24</div>
        <div class="stat-sub" style="color:var(--brand2);">↑ +3 respecto a ayer</div>
      </div>

      <div class="stat-card">
        <div class="stat-top">
          <div class="stat-label">Beneficios este mes</div>
          <div class="stat-icon" style="background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.15);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
          </div>
        </div>
        <div class="stat-value" style="color:#60a5fa;">218</div>
        <div class="stat-sub" style="color:#60a5fa;">↑ +12% vs. mes anterior</div>
      </div>

      <div class="stat-card">
        <div class="stat-top">
          <div class="stat-label">Clientes únicos activos</div>
          <div class="stat-icon" style="background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.15);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
        </div>
        <div class="stat-value" style="color:var(--amber);">89</div>
        <div class="stat-sub" style="color:var(--amber);">↑ +7 este mes</div>
      </div>

    </div>

    <!-- Charts row -->
    <div class="charts-row">

      <!-- Bar chart -->
      <div class="card card-pad">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <div>
            <div class="card-title">Actividad semanal</div>
            <div class="card-sub">Validaciones por día — últimos 7 días</div>
          </div>
          <span class="badge b-green">+18% ↑</span>
        </div>

        <div class="chart-wrap">
          <!-- Y axis -->
          <div class="y-labels">
            <span>30</span>
            <span>20</span>
            <span>10</span>
            <span>0</span>
          </div>
          <!-- Chart -->
          <div class="chart-inner">
            <svg class="chart-svg" viewBox="0 0 560 120" preserveAspectRatio="none">
              <!-- Grid lines -->
              <line x1="0" y1="0"   x2="560" y2="0"   stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
              <line x1="0" y1="40"  x2="560" y2="40"  stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
              <line x1="0" y1="80"  x2="560" y2="80"  stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
              <line x1="0" y1="120" x2="560" y2="120" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

              <!-- Bars: values [14,19,11,25,22,28,30] scaled to 120px (max=30) -->
              <!-- Lun 14 → h=56 -->
              <rect class="bar-rect" x="8"   y="64"  width="62" height="56"  rx="5" fill="rgba(36,150,125,0.28)"/>
              <!-- Mar 19 → h=76 -->
              <rect class="bar-rect" x="88"  y="44"  width="62" height="76"  rx="5" fill="rgba(36,150,125,0.36)"/>
              <!-- Mié 11 → h=44 -->
              <rect class="bar-rect" x="168" y="76"  width="62" height="44"  rx="5" fill="rgba(36,150,125,0.24)"/>
              <!-- Jue 25 → h=100 -->
              <rect class="bar-rect" x="248" y="20"  width="62" height="100" rx="5" fill="rgba(36,150,125,0.48)"/>
              <!-- Vie 22 → h=88 -->
              <rect class="bar-rect" x="328" y="32"  width="62" height="88"  rx="5" fill="rgba(36,150,125,0.42)"/>
              <!-- Sáb 28 → h=112 -->
              <rect class="bar-rect" x="408" y="8"   width="62" height="112" rx="5" fill="rgba(36,150,125,0.55)"/>
              <!-- Hoy 30 → h=120 (full, solid) -->
              <rect class="bar-rect" x="488" y="0"   width="62" height="120" rx="5" fill="#24967D" style="filter:drop-shadow(0 0 6px rgba(36,150,125,0.45))"/>

              <!-- Value labels -->
              <text x="39"  y="59"  text-anchor="middle" font-size="10" fill="rgba(255,255,255,0.28)" font-family="Inter,sans-serif">14</text>
              <text x="119" y="39"  text-anchor="middle" font-size="10" fill="rgba(255,255,255,0.28)" font-family="Inter,sans-serif">19</text>
              <text x="199" y="71"  text-anchor="middle" font-size="10" fill="rgba(255,255,255,0.28)" font-family="Inter,sans-serif">11</text>
              <text x="279" y="15"  text-anchor="middle" font-size="10" fill="rgba(255,255,255,0.38)" font-family="Inter,sans-serif">25</text>
              <text x="359" y="27"  text-anchor="middle" font-size="10" fill="rgba(255,255,255,0.35)" font-family="Inter,sans-serif">22</text>
              <text x="439" y="3"   text-anchor="middle" font-size="10" fill="rgba(255,255,255,0.42)" font-family="Inter,sans-serif">28</text>
              <text x="519" y="-7"  text-anchor="middle" font-size="11" fill="#2db896" font-weight="700" font-family="Inter,sans-serif">30</text>
            </svg>

            <!-- X labels -->
            <div class="x-labels">
              <span>Lun</span>
              <span>Mar</span>
              <span>Mié</span>
              <span>Jue</span>
              <span>Vie</span>
              <span>Sáb</span>
              <span class="today">Hoy</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Beneficio activo -->
      <div class="card card-pad" style="display:flex;flex-direction:column;">
        <div class="card-title">Beneficio activo</div>
        <div class="card-sub" style="margin-bottom:16px;">Configurado por Kuntur Training</div>

        <div class="benefit-box">
          <div class="benefit-eyebrow">Descuento habilitado</div>
          <div class="benefit-pct">20%</div>
          <div class="benefit-off">OFF</div>
          <div class="benefit-desc">En consumo de cafetería</div>
        </div>

        <div class="benefit-note">
          Válido para socios con plan<br/>Premium y Standard
        </div>
      </div>

    </div>

    <!-- Últimas validaciones -->
    <div class="table-card">
      <div class="table-header">
        <div>
          <div class="card-title">Últimas validaciones</div>
          <div class="card-sub" style="margin-top:2px;">Registro de socios validados hoy</div>
        </div>
        <button class="tbl-action">Ver todo →</button>
      </div>

      <div style="overflow-x:auto;">
        <table>
          <thead>
            <tr>
              <th>Socio</th>
              <th>DNI</th>
              <th>Estado</th>
              <th>Plan</th>
              <th>Beneficio</th>
              <th>Hora</th>
            </tr>
          </thead>
          <tbody>
            {[
              { ini:'JP', nombre:'Juan Pérez',    dni:'32.456.789', estado:'Activo',     plan:'Premium',  hora:'10:23', av:'av-brand',  badge:'b-green', pulse:true  },
              { ini:'ML', nombre:'María López',   dni:'28.123.456', estado:'Activa',     plan:'Standard', hora:'09:48', av:'av-brand',  badge:'b-green', pulse:true  },
              { ini:'CR', nombre:'Carlos Ruiz',   dni:'41.789.012', estado:'Inactivo',   plan:'—',        hora:'09:31', av:'av-danger', badge:'b-red',   pulse:false },
              { ini:'AG', nombre:'Ana Giménez',   dni:'35.654.321', estado:'Activa',     plan:'Premium',  hora:'09:12', av:'av-brand',  badge:'b-green', pulse:true  },
              { ini:'PT', nombre:'Pablo Torres',  dni:'30.987.654', estado:'Por vencer', plan:'Standard', hora:'08:55', av:'av-amber',  badge:'b-amber', pulse:false },
            ].map(row => (
              <tr>
                <td>
                  <div style="display:flex;align-items:center;gap:9px;">
                    <div class={`avatar ${row.av}`}>{row.ini}</div>
                    <span style="font-weight:500;color:white;">{row.nombre}</span>
                  </div>
                </td>
                <td style="color:var(--text2);font-family:monospace;font-size:12px;">{row.dni}</td>
                <td>
                  <span class={`badge ${row.badge}`}>
                    {row.pulse && <span class="dot-pulse"></span>}
                    {row.estado}
                  </span>
                </td>
                <td>
                  {row.plan !== '—'
                    ? <span class={`badge ${row.plan === 'Premium' ? 'b-blue' : 'b-gray'}`}>{row.plan}</span>
                    : <span style="color:var(--text3);">—</span>
                  }
                </td>
                <td>
                  {row.badge !== 'b-red'
                    ? <span class="benefit-tag">20% OFF</span>
                    : <span style="font-size:12px;color:var(--text3);">Sin beneficio</span>
                  }
                </td>
                <td style="color:var(--text3);font-size:12px;">{row.hora}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

  </main>
</BaseLayout>