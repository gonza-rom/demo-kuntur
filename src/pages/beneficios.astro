---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';

const comercios = [
  { id: 1, nombre: "Café Central", rubro: "Gastronomía", cat: "gastronomia", color: "#7c5c3e", beneficio: "20% OFF", beneficioDesc: "En todo el consumo", direccion: "Av. República 341", horarios: "Lun–Vie 7:00–20:00", condiciones: "No acumulable. Válido para socios con plan activo. Máx. 1 uso por día.", usos: 891, destacado: true, nuevo: false },
  { id: 2, nombre: "Barber Club Elite", rubro: "Barbería", cat: "barberia", color: "#1e3a5f", beneficio: "15% OFF", beneficioDesc: "En cortes y arreglo de barba", direccion: "Belgrano 128, local 2", horarios: "Lun–Sáb 9:00–20:00", condiciones: "Válido de lunes a sábados. No aplica fin de semana con agenda completa.", usos: 654, destacado: true, nuevo: false },
  { id: 3, nombre: "NutriFit Consultoría", rubro: "Nutrición deportiva", cat: "nutricion", color: "#14532d", beneficio: "1ª consulta gratis", beneficioDesc: "Evaluación sin costo", direccion: "San Martín 55, piso 1", horarios: "Lun–Vie 9:00–18:00", condiciones: "Un beneficio por socio. Consultas siguientes con 15% adicional.", usos: 422, destacado: false, nuevo: false },
  { id: 4, nombre: "SportWear Store", rubro: "Indumentaria deportiva", cat: "indumentaria", color: "#1e1b4b", beneficio: "10% OFF", beneficioDesc: "En ropa y accesorios", direccion: "Pellegrini 204", horarios: "Lun–Sáb 9:30–13:00 · 16:30–20:30", condiciones: "No aplica sobre artículos en liquidación.", usos: 380, destacado: false, nuevo: false },
  { id: 5, nombre: "Farmacia Vital", rubro: "Farmacia", cat: "salud", color: "#065f46", beneficio: "8% OFF", beneficioDesc: "En medicamentos y salud", direccion: "Urquiza 440", horarios: "Lun–Dom 8:00–22:00", condiciones: "No aplica en recetas magistrales ni promos ya rebajadas.", usos: 245, destacado: false, nuevo: true },
  { id: 6, nombre: "ProSuplementos", rubro: "Suplementación deportiva", cat: "suplementos", color: "#7c2d12", beneficio: "18% OFF", beneficioDesc: "En toda la línea", direccion: "25 de Mayo 12", horarios: "Lun–Vie 10:00–20:00 · Sáb 10:00–14:00", condiciones: "Máximo 2 productos por visita con el descuento.", usos: 312, destacado: true, nuevo: false },
  { id: 7, nombre: "Centro Kinésico Movimiento", rubro: "Kinesiología", cat: "bienestar", color: "#312e81", beneficio: "1ª sesión gratis", beneficioDesc: "Evaluación kinesiológica", direccion: "Salta 88, local 3", horarios: "Lun–Vie 8:00–19:00", condiciones: "Un beneficio por socio al año. Sesiones posteriores 10% off.", usos: 156, destacado: false, nuevo: true },
  { id: 8, nombre: "Pizzería Don Remo", rubro: "Gastronomía", cat: "gastronomia", color: "#7f1d1d", beneficio: "2×1", beneficioDesc: "Lunes y martes en pizzas", direccion: "Lavalle 789", horarios: "Mar–Dom 19:00–23:30", condiciones: "Solo lunes y martes. No incluye empanadas.", usos: 198, destacado: false, nuevo: false },
  { id: 9, nombre: "Heladería Glacé", rubro: "Gastronomía", cat: "gastronomia", color: "#831843", beneficio: "25% OFF", beneficioDesc: "En línea artesanal", direccion: "Rivadavia 200", horarios: "Mar–Dom 14:00–22:00", condiciones: "No aplica en ediciones especiales ni tortas por encargo.", usos: 287, destacado: true, nuevo: false },
  { id: 10, nombre: "RunLab Calzado", rubro: "Indumentaria deportiva", cat: "indumentaria", color: "#0c4a6e", beneficio: "12% OFF", beneficioDesc: "En zapatillas deportivas", direccion: "Mota Botello 320", horarios: "Lun–Sáb 9:00–13:00 · 17:00–21:00", condiciones: "Válido con stock disponible.", usos: 143, destacado: false, nuevo: true },
  { id: 11, nombre: "ProteinBox", rubro: "Suplementos y nutrición", cat: "suplementos", color: "#3b0764", beneficio: "15% OFF", beneficioDesc: "En proteínas y vitaminas", direccion: "San Martín 142", horarios: "Lun–Vie 9:00–19:00", condiciones: "No aplica sobre combos ya rebajados.", usos: 210, destacado: false, nuevo: true },
  { id: 12, nombre: "Studio Pilates Core", rubro: "Bienestar y fitness", cat: "bienestar", color: "#134e4a", beneficio: "1 clase gratis", beneficioDesc: "Clase de prueba sin costo", direccion: "Av. Virgen del Valle 85", horarios: "Lun–Sáb 7:00–21:00", condiciones: "Solo para quienes nunca hayan asistido. Sujeto a disponibilidad.", usos: 98, destacado: false, nuevo: true },
];

const categorias = [
  { id: '', label: 'Todos', count: 12 },
  { id: 'gastronomia', label: 'Gastronomía', count: 3 },
  { id: 'barberia', label: 'Barberías', count: 1 },
  { id: 'nutricion', label: 'Nutrición', count: 1 },
  { id: 'indumentaria', label: 'Indumentaria', count: 2 },
  { id: 'salud', label: 'Salud', count: 1 },
  { id: 'bienestar', label: 'Bienestar', count: 2 },
  { id: 'suplementos', label: 'Suplementos', count: 2 },
];
---

<BaseLayout title="Beneficios para Socios — Kuntur Benefits">
  <Navbar currentPage="/beneficios" />

  <main class="pt-16">

    <!-- HERO -->
    <section class="relative py-20 px-6 text-center overflow-hidden">
      <div class="absolute inset-0 z-0" style="background-image: linear-gradient(rgba(26,159,125,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(26,159,125,0.04) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, black 20%, transparent 80%);"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] rounded-full bg-brand-500/[0.06] blur-3xl pointer-events-none z-0"></div>

      <div class="relative z-10 max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-[12px] font-medium mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
          Exclusivo para socios activos Kuntur Training
        </div>
        <h1 class="font-display font-800 text-[clamp(32px,5vw,56px)] leading-[1.05] tracking-[-1.5px] text-white mb-4">
          Beneficios <span class="text-brand-400">exclusivos</span><br/>para socios Kuntur
        </h1>
        <p class="text-[16px] text-white/50 leading-relaxed max-w-lg mx-auto mb-8">
          Accedé a descuentos y promociones especiales en los mejores comercios de la ciudad, solo por ser parte de Kuntur Training.
        </p>

        <!-- Search -->
        <div class="flex items-center gap-3 max-w-xl mx-auto bg-white/[0.04] border border-white/[0.08] rounded-full px-4 py-2 focus-within:border-brand-500/40 transition-colors duration-200">
          <svg class="w-4 h-4 text-white/30 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            id="search-input"
            type="text"
            placeholder="Buscar comercio o beneficio…"
            class="flex-1 bg-transparent text-[14px] text-white placeholder:text-white/30 outline-none py-1.5"
            autocomplete="off"
          />
          <select id="cat-select" class="bg-transparent text-[13px] text-white/50 outline-none cursor-pointer pr-1">
            <option value="">Todas las categorías</option>
            <option value="gastronomia">Gastronomía</option>
            <option value="barberia">Barberías</option>
            <option value="nutricion">Nutrición</option>
            <option value="indumentaria">Indumentaria</option>
            <option value="salud">Salud</option>
            <option value="bienestar">Bienestar</option>
            <option value="suplementos">Suplementos</option>
          </select>
        </div>

        <!-- Stats -->
        <div class="flex items-center justify-center gap-6 mt-8 flex-wrap">
          {[
            { value: '1,243', label: 'beneficios usados este mes' },
            { value: '12', label: 'comercios adheridos' },
            { value: '7', label: 'categorías disponibles' },
          ].map((s, i) => (
            <>
              {i > 0 && <div class="w-px h-5 bg-white/[0.08]"></div>}
              <div class="flex items-center gap-2 text-[13px] text-white/40">
                <span class="font-display font-700 text-[15px] text-white">{s.value}</span>
                {s.label}
              </div>
            </>
          ))}
        </div>
      </div>
    </section>

    <!-- CATEGORY PILLS -->
    <div class="px-6 border-b border-white/[0.06]">
      <div class="max-w-7xl mx-auto">
        <div id="cat-pills" class="flex gap-2 overflow-x-auto py-4 scrollbar-hide">
          {categorias.map(cat => (
            <button
              class="cat-pill flex items-center gap-2 px-4 py-2 rounded-full border text-[13px] font-medium whitespace-nowrap transition-all duration-150 shrink-0"
              data-cat={cat.id}
              class:list={[
                cat.id === ''
                  ? 'bg-brand-500/10 border-brand-500/30 text-brand-300'
                  : 'bg-white/[0.03] border-white/[0.06] text-white/50 hover:text-white/80 hover:border-white/[0.12]'
              ]}
            >
              {cat.label}
              <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-white/[0.06] text-white/35">{cat.count}</span>
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- GRID -->
    <section class="py-8 px-6 pb-20">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-6">
          <p id="result-count" class="text-[13px] text-white/40"><span id="count-num">12</span> comercios adheridos</p>
          <select id="sort-select" class="bg-white/[0.04] border border-white/[0.08] text-white/60 text-[13px] px-3 py-2 rounded-lg outline-none">
            <option value="relevancia">Relevancia</option>
            <option value="usos">Más usados</option>
            <option value="nombre">Nombre A→Z</option>
          </select>
        </div>

        <div id="cards-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
          {comercios.map(c => (
            <div
              class="mkt-card bg-[#0c0f0e] border border-white/[0.06] rounded-2xl overflow-hidden flex flex-col cursor-pointer group hover:-translate-y-1 hover:border-brand-500/30 transition-all duration-200"
              data-cat={c.cat}
              data-nombre={c.nombre.toLowerCase()}
              data-rubro={c.rubro.toLowerCase()}
              data-usos={c.usos}
              data-id={c.id}
              data-beneficio={c.beneficio}
              data-desc={c.beneficioDesc}
              data-dir={c.direccion}
              data-horarios={c.horarios}
              data-cond={c.condiciones}
            >
              <!-- Banner -->
              <div class="h-24 flex items-center justify-center relative overflow-hidden" style={`background: ${c.color}22;`}>
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl border border-white/10 relative z-10" style={`background: ${c.color}44;`}>
                  {c.cat === 'gastronomia' && <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>}
                  {c.cat === 'barberia' && <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>}
                  {c.cat === 'nutricion' && <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                  {c.cat === 'indumentaria' && <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg>}
                  {c.cat === 'salud' && <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>}
                  {c.cat === 'bienestar' && <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>}
                  {c.cat === 'suplementos' && <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>}
                </div>
                {c.nuevo && <span class="absolute top-2 left-2 text-[10px] font-bold px-2 py-0.5 rounded-full bg-violet-500/20 border border-violet-500/30 text-violet-300">Nuevo</span>}
                {c.destacado && <span class="absolute top-2 right-2 text-[11px] text-amber-400/70">★</span>}
                <span class="absolute bottom-2 right-2 flex items-center gap-1 text-[10px] text-brand-400/70">
                  <span class="w-1 h-1 rounded-full bg-brand-400 animate-pulse"></span>
                  Adherido
                </span>
              </div>

              <!-- Body -->
              <div class="p-4 flex flex-col gap-3 flex-1">
                <div>
                  <p class="font-display font-700 text-[14px] text-white">{c.nombre}</p>
                  <p class="text-[12px] text-white/40 mt-0.5">{c.rubro}</p>
                </div>
                <div class="flex items-center gap-1.5 text-[11.5px] text-white/30">
                  <svg class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {c.direccion}
                </div>

                <!-- Benefit box -->
                <div class="mt-auto bg-white/[0.03] border border-white/[0.06] rounded-xl p-3 flex items-center justify-between group-hover:border-brand-500/20 transition-colors duration-200">
                  <div>
                    <p class="font-display font-800 text-[22px] text-brand-400 leading-none">{c.beneficio}</p>
                    <p class="text-[11px] text-white/40 mt-1">{c.beneficioDesc}</p>
                  </div>
                  <svg class="w-4 h-4 text-white/20 group-hover:text-brand-400 group-hover:translate-x-0.5 transition-all duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
              </div>

              <!-- Footer -->
              <div class="px-4 py-3 border-t border-white/[0.05] flex items-center justify-between">
                <span class="flex items-center gap-1.5 text-[11px] text-white/30">
                  <span class="w-1 h-1 rounded-full bg-brand-400/50 animate-pulse"></span>
                  {c.usos.toLocaleString()} usos este mes
                </span>
                <button class="open-modal text-[11.5px] font-medium text-brand-400/70 hover:text-brand-300 transition-colors">
                  Ver detalle →
                </button>
              </div>
            </div>
          ))}
        </div>

        <!-- No results -->
        <div id="no-results" class="hidden text-center py-16">
          <div class="w-14 h-14 rounded-2xl bg-white/[0.04] border border-white/[0.06] flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <p class="font-display font-600 text-[15px] text-white/40 mb-1">Sin resultados</p>
          <p class="text-[13px] text-white/25">No encontramos comercios con esos filtros.</p>
        </div>
      </div>
    </section>

    <!-- HOW TO -->
    <section class="py-20 px-6 bg-white/[0.02] border-t border-white/[0.06]">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-brand-400 text-[11px] font-bold uppercase tracking-widest mb-3">Proceso</p>
          <h2 class="font-display font-700 text-[32px] text-white tracking-tight">¿Cómo accedo a los beneficios?</h2>
          <p class="text-white/45 text-[15px] mt-3">Simple, rápido y sin necesidad de apps. Solo tu DNI.</p>
        </div>
        <div class="grid md:grid-cols-4 gap-6 relative">
          <div class="absolute top-6 left-[12.5%] right-[12.5%] h-px bg-brand-500/20 hidden md:block"></div>
          {[
            { icon: 'store', title: 'Visitá el comercio', text: 'Acercate a cualquier comercio adherido que encontrés en esta página.' },
            { icon: 'id', title: 'Presentá tu DNI', text: 'Mostrá tu DNI físico al empleado del local. Sin apps, sin tarjetas.' },
            { icon: 'check', title: 'Validación instantánea', text: 'El sistema verifica tu membresía activa en tiempo real en segundos.' },
            { icon: 'gift', title: '¡Disfrutá el beneficio!', text: 'Si tu membresía está activa, el descuento se aplica automáticamente.' },
          ].map(step => (
            <div class="flex flex-col items-center text-center relative z-10">
              <div class="w-12 h-12 rounded-full bg-[#0c0f0e] border border-brand-500/30 flex items-center justify-center mb-4 hover:bg-brand-500/10 hover:scale-105 transition-all duration-200">
                {step.icon === 'store' && <svg class="w-5 h-5 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>}
                {step.icon === 'id' && <svg class="w-5 h-5 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>}
                {step.icon === 'check' && <svg class="w-5 h-5 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>}
                {step.icon === 'gift' && <svg class="w-5 h-5 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>}
              </div>
              <p class="font-display font-700 text-[14px] text-white mb-2">{step.title}</p>
              <p class="text-[13px] text-white/40 leading-relaxed">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="border-t border-white/[0.06] py-8 px-6">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 rounded-lg bg-brand-500 flex items-center justify-center">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
          </div>
          <span class="font-display font-700 text-[14px]">Kuntur <span class="text-brand-400">Benefits</span></span>
        </div>
        <p class="text-[12px] text-white/25">Powered by <span class="text-brand-400 font-medium">Devhub</span> · Catamarca, Argentina</p>
      </div>
    </footer>
  </main>

  <!-- MODAL OVERLAY -->
  <div id="modal-overlay" class="fixed inset-0 z-[200] bg-black/80 backdrop-blur-sm hidden items-center justify-center p-6">
    <div id="modal-box" class="w-full max-w-md bg-[#0d1210] border border-white/[0.08] rounded-2xl overflow-hidden max-h-[90vh] overflow-y-auto">
    </div>
  </div>
</BaseLayout>

<script define:vars={{ comercios }}>
  // Filter state
  let activeCat = '';
  let searchVal = '';
  let sortVal = 'relevancia';

  const cards = document.querySelectorAll('.mkt-card');
  const noResults = document.getElementById('no-results');
  const countEl = document.getElementById('count-num');

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const cat = card.dataset.cat;
      const nombre = card.dataset.nombre;
      const rubro = card.dataset.rubro;
      const q = searchVal.toLowerCase();
      const matchCat = !activeCat || cat === activeCat;
      const matchSearch = !q || nombre.includes(q) || rubro.includes(q);
      if (matchCat && matchSearch) {
        card.style.display = 'flex';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });
    countEl.textContent = visible;
    noResults.classList.toggle('hidden', visible > 0);
  }

  // Category pills
  document.querySelectorAll('.cat-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.cat-pill').forEach(p => {
        p.className = 'cat-pill flex items-center gap-2 px-4 py-2 rounded-full border text-[13px] font-medium whitespace-nowrap transition-all duration-150 shrink-0 bg-white/[0.03] border-white/[0.06] text-white/50 hover:text-white/80 hover:border-white/[0.12]';
      });
      pill.className = 'cat-pill flex items-center gap-2 px-4 py-2 rounded-full border text-[13px] font-medium whitespace-nowrap transition-all duration-150 shrink-0 bg-brand-500/10 border-brand-500/30 text-brand-300';
      activeCat = pill.dataset.cat;
      const sel = document.getElementById('cat-select');
      if (sel) sel.value = activeCat;
      applyFilters();
    });
  });

  document.getElementById('search-input')?.addEventListener('input', e => {
    searchVal = e.target.value;
    applyFilters();
  });

  document.getElementById('cat-select')?.addEventListener('change', e => {
    activeCat = e.target.value;
    document.querySelectorAll('.cat-pill').forEach(p => {
      p.className = p.dataset.cat === activeCat
        ? 'cat-pill flex items-center gap-2 px-4 py-2 rounded-full border text-[13px] font-medium whitespace-nowrap transition-all duration-150 shrink-0 bg-brand-500/10 border-brand-500/30 text-brand-300'
        : 'cat-pill flex items-center gap-2 px-4 py-2 rounded-full border text-[13px] font-medium whitespace-nowrap transition-all duration-150 shrink-0 bg-white/[0.03] border-white/[0.06] text-white/50 hover:text-white/80 hover:border-white/[0.12]';
    });
    applyFilters();
  });

  // MODAL
  const overlay = document.getElementById('modal-overlay');
  const modalBox = document.getElementById('modal-box');

  function openModal(card) {
    const id = parseInt(card.dataset.id);
    const c = comercios.find(x => x.id === id);
    if (!c) return;

    modalBox.innerHTML = `
      <div class="p-6 border-b border-white/[0.06] flex items-start justify-between gap-4">
        <div>
          <p class="font-display font-800 text-[18px] text-white">${c.nombre}</p>
          <p class="text-[13px] text-white/40 mt-0.5">${c.rubro} · ${c.direccion}</p>
        </div>
        <button id="close-modal" class="w-8 h-8 rounded-lg bg-white/[0.06] flex items-center justify-center text-white/40 hover:text-white hover:bg-white/[0.10] transition-all shrink-0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="p-6">
        <div class="bg-brand-500/10 border border-brand-500/20 rounded-xl p-5 text-center mb-5">
          <p class="font-display font-800 text-[40px] text-brand-400 leading-none">${c.beneficio}</p>
          <p class="text-[13px] text-white/50 mt-2">${c.beneficioDesc}</p>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-5">
          <div class="bg-white/[0.03] rounded-xl p-3">
            <p class="text-[10px] text-white/30 uppercase tracking-wider mb-1">Horarios</p>
            <p class="text-[13px] text-white/70">${c.horarios}</p>
          </div>
          <div class="bg-white/[0.03] rounded-xl p-3">
            <p class="text-[10px] text-white/30 uppercase tracking-wider mb-1">Usos este mes</p>
            <p class="text-[13px] font-display font-700 text-brand-400">${c.usos.toLocaleString()} socios</p>
          </div>
        </div>
        <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 mb-5">
          <p class="text-[12px] font-bold text-white/50 mb-3">¿Cómo acceder?</p>
          ${[
            `Acercate a <strong class="text-white">${c.nombre}</strong> en ${c.direccion}`,
            'Presentá tu <strong class="text-white">DNI físico</strong> al empleado del local',
            'El sistema verifica tu membresía activa en Kuntur Benefits',
            `El beneficio <strong class="text-brand-400">${c.beneficio}</strong> se aplica automáticamente`
          ].map((s, i) => `
            <div class="flex gap-3 mb-3 last:mb-0">
              <div class="w-5 h-5 rounded-full bg-brand-500/20 border border-brand-500/30 flex items-center justify-center text-[9px] font-bold text-brand-400 shrink-0 mt-0.5">${i+1}</div>
              <p class="text-[13px] text-white/50 leading-relaxed">${s}</p>
            </div>
          `).join('')}
        </div>
        <div>
          <p class="text-[10px] text-white/25 uppercase tracking-wider mb-2">Condiciones</p>
          <p class="text-[12px] text-white/35 leading-relaxed">${c.condiciones}</p>
        </div>
      </div>
      <div class="p-4 border-t border-white/[0.06] bg-white/[0.02]">
        <button id="close-modal-btn" class="w-full py-3 rounded-xl bg-brand-500 text-white font-display font-600 text-[14px] hover:bg-brand-400 transition-colors">Entendido ✓</button>
      </div>
    `;

    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';

    document.getElementById('close-modal')?.addEventListener('click', closeModal);
    document.getElementById('close-modal-btn')?.addEventListener('click', closeModal);
  }

  function closeModal() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
  }

  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  document.querySelectorAll('.mkt-card').forEach(card => {
    card.addEventListener('click', () => openModal(card));
  });
</script>