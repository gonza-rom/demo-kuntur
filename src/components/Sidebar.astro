---
export interface Props {
  role?: 'comercio' | 'admin';
  currentPage?: string;
  comercioName?: string;
}
const { role = 'comercio', currentPage = '', comercioName = 'Cafetería Mitre' } = Astro.props;

const comercioLinks = [
  { href: '/dashboard',     label: 'Dashboard',     icon: 'ti-chart-bar' },
  { href: '/validar',       label: 'Validar Socio', icon: 'ti-circle-check', badge: 'Nuevo' },
  { href: '/historial',     label: 'Historial',     icon: 'ti-list' },
  { href: '/mis-beneficios',label: 'Mis Beneficios',icon: 'ti-gift' },
];

const adminLinks = [
  { href: '/admin',               label: 'Analytics',    icon: 'ti-chart-bar' },
  { href: '/admin/comercios',     label: 'Comercios',    icon: 'ti-building-store' },
  { href: '/admin/socios',        label: 'Socios',       icon: 'ti-users', count: '1284' },
  { href: '/admin/validaciones',  label: 'Validaciones', icon: 'ti-circle-check' },
  { href: '/admin/beneficios',    label: 'Beneficios',   icon: 'ti-gift' },
];

const links = role === 'admin' ? adminLinks : comercioLinks;
const initials = comercioName.split(' ').map((w: string) => w[0]).join('').slice(0, 2);
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"
/>

<aside class="fixed top-16 left-0 bottom-0 w-[220px] bg-[#0c0f0e] border-r border-white/[0.06] flex flex-col z-40 overflow-y-auto">

  <!-- Header -->
  <div class="p-4 border-b border-white/[0.06]">
    <div class="flex items-center gap-3">
      <div class={`w-8 h-8 rounded-lg flex items-center justify-center text-[11px] font-display font-bold text-white shrink-0 ${role === 'admin' ? 'bg-rose-500/80' : 'bg-brand-500/80'}`}>
        {role === 'admin' ? 'KT' : initials}
      </div>
      <div class="min-w-0">
        <p class="text-[13px] font-medium text-white truncate">
          {role === 'admin' ? 'Kuntur Training' : comercioName}
        </p>
        <p class="text-[11px] text-white/40">
          {role === 'admin' ? 'Super Admin' : 'Comercio adherido'}
        </p>
      </div>
    </div>

    {role === 'admin' && (
      <div class="mt-3 px-2 py-1 rounded-md bg-rose-500/10 border border-rose-500/20 flex items-center justify-center gap-1.5 text-center">
        <i class="ti ti-bolt text-rose-400 text-[13px]" aria-hidden="true"></i>
        <span class="text-[11px] font-bold text-rose-400 tracking-wider uppercase">Admin</span>
      </div>
    )}

    {role === 'comercio' && (
      <div class="mt-3 px-2 py-1 rounded-md bg-brand-500/10 border border-brand-500/20 flex items-center justify-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
        <span class="text-[11px] font-medium text-brand-400">Sistema Activo</span>
      </div>
    )}
  </div>

  <!-- Nav -->
  <nav class="flex-1 p-3 space-y-0.5">
    {role === 'admin' && (
      <p class="text-[10px] font-bold text-white/25 uppercase tracking-widest px-2 pb-2 pt-1">
        Principal
      </p>
    )}

    {links.map(link => (
      <a
        href={link.href}
        class={`group flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-all duration-150
          ${currentPage === link.href
            ? 'bg-brand-500/15 text-white border border-brand-500/20'
            : 'text-white/45 hover:text-white/90 hover:bg-white/[0.04]'
          }`}
      >
        <i class={`ti ${link.icon} text-[16px] shrink-0`} aria-hidden="true"></i>

        <span class="flex-1">{link.label}</span>

        {link.badge && (
          <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-brand-500/20 text-brand-400 border border-brand-500/25">
            {link.badge}
          </span>
        )}
        {link.count && (
          <span class="text-[11px] px-2 py-0.5 rounded-full bg-white/[0.06] text-white/35">
            {link.count}
          </span>
        )}
      </a>
    ))}

    <!-- Cuenta -->
    <div class="pt-4 mt-2 border-t border-white/[0.05] space-y-0.5">
      <p class="text-[10px] font-bold text-white/25 uppercase tracking-widest px-2 pb-2">
        Cuenta
      </p>

      <a
        href="/configuracion"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium text-white/45 hover:text-white/90 hover:bg-white/[0.04] transition-all duration-150"
      >
        <i class="ti ti-settings text-[16px] shrink-0" aria-hidden="true"></i>
        Configuración
      </a>

      <a
        href="/login"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium text-white/45 hover:text-white/90 hover:bg-white/[0.04] transition-all duration-150"
      >
        <i class="ti ti-logout text-[16px] shrink-0" aria-hidden="true"></i>
        Cerrar sesión
      </a>
    </div>
  </nav>

  <!-- Footer -->
  <div class="p-4 border-t border-white/[0.06]">
    <p class="text-[10px] text-white/20 text-center">Devhub · Kuntur Benefits v1.0</p>
  </div>

</aside>