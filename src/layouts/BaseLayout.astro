---
import Navbar from '../components/Navbar.astro';

export interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
}
const { 
  title = 'Kuntur Benefits', 
  description = 'Ecosistema de beneficios exclusivos para socios activos de Kuntur Training',
  currentPage = ''
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body class="bg-[#080a09] text-[#f0f4f2] min-h-screen">

  <Navbar currentPage={currentPage} />

  <main class="pt-16">
    <slot />
  </main>

  <script>
    // Hamburger menu
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));

    // Demo dropdown
    const demoBtn = document.getElementById('demo-btn');
    const demoMenu = document.getElementById('demo-menu');
    const demoChevron = document.getElementById('demo-chevron');

    demoBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !demoMenu?.classList.contains('hidden');
      demoMenu?.classList.toggle('hidden');
      demoChevron?.classList.toggle('rotate-180', !isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!document.getElementById('demo-dropdown-wrapper')?.contains(e.target as Node)) {
        demoMenu?.classList.add('hidden');
        demoChevron?.classList.remove('rotate-180');
      }
    });
  </script>

</body>
</html>